def _ensure_ml_imports() -> None:
    """Prefer the project venv site-packages so transformers/torch resolve."""
    venv_py = Path(_ml_python())
    if venv_py == Path(sys.executable):
        return
    # Typical layout: …/.venv/lib/pythonX.Y/site-packages
    for site in venv_py.parent.parent.glob("lib/python*/site-packages"):
        sp = str(site)
        if sp not in sys.path:
            sys.path.insert(0, sp)
        break
    for site in venv_py.parent.parent.glob("Lib/site-packages"):
        sp = str(site)
        if sp not in sys.path:
            sys.path.insert(0, sp)
        break


