    _write_kestrel_meta(dest, mid, entry, runner=False, chat=entry.get("chat") or "engine-oracle")
    print(f"done (engine demo fixture → {dest})")
    return 0


def _install_preview(mid: str, entry: dict, dest: Path) -> int:
