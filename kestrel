    return subprocess.call(["make", "ARCH=native"], cwd=str(ENGINE_DIR))


def cmd_oracle(_: argparse.Namespace) -> int:
    if not ENGINE_BIN.is_file() and cmd_build(argparse.Namespace()) != 0:
        return 1
    env = os.environ.copy()
    env["SNAP"] = "./fixtures/glm_tiny"
    env["TF"] = "1"
    return subprocess.call(
        [str(ENGINE_BIN), "64", "16", "16"], cwd=str(ENGINE_DIR), env=env
    )


