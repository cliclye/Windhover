def _fmt_bytes(n: float) -> str:
    n = float(max(0, n))
    for unit, div in (("GB", 1e9), ("MB", 1e6), ("KB", 1e3)):
        if n >= div:
            return f"{n / div:.2f} {unit}"
    return f"{int(n)} B"


def _dir_bytes(path: Path) -> int:
    total = 0
    if not path.is_dir():
        return 0
    for p in path.rglob("*"):
        if p.is_file():
            try:
                total += p.stat().st_size
            except OSError:
                pass
    return total


def _weight_bytes(snap: Path) -> int:
    total = 0
    if not snap.is_dir():
        return 0
    for p in snap.rglob("*"):
        if not p.is_file():
            continue
        if p.suffix.lower() in {".safetensors", ".bin", ".gguf", ".pt", ".pth"}:
            try:
                total += p.stat().st_size
            except OSError:
                pass
    return total


def _has_real_weights(snap: Path, min_bytes: int = 30_000_000) -> bool:
    """True when a local checkout has substantial model weight files."""
    return _weight_bytes(snap) >= min_bytes


def _job_set(job_id: str, **kwargs) -> None:
    with _PULL_LOCK:
        job = _PULL_JOBS.setdefault(job_id, {"job_id": job_id})
        job.update(kwargs)
        job["updated_at"] = time.time()


def _job_get(job_id: str) -> dict | None:
    with _PULL_LOCK:
        job = _PULL_JOBS.get(job_id)
        return dict(job) if job else None


def _snap_meta(snap: Path) -> dict:
    kj = snap / "kestrel.json"
    if kj.is_file():
        try:
            return json.loads(kj.read_text())
        except json.JSONDecodeError:
            return {}
    return {}


def _is_tiny_stub(snap: Path) -> bool:
    st = snap / "model.safetensors"
    return st.is_file() and st.stat().st_size < 20_000_000


def _is_impostor_pack(snap: Path) -> bool:
    """True if a tiny/empty stub was labeled as a real HF model."""
    meta = _snap_meta(snap)
    mid = str(meta.get("id") or snap.name).replace("__", "/")
    if mid.startswith(("windhover/chat-preview", "kestrel/chat-preview")) or mid.startswith(("windhover/glm-tiny", "kestrel/glm-tiny")):
        return False
    if meta.get("impostor") is True:
        return True
    if meta.get("runner") is True and not mid.startswith(("windhover/", "kestrel/")):
        return True
    # Empty marker installs (the instant “Install” bug) claiming to be Qwen/etc.
    if meta.get("chat") == "preview" and not _has_real_weights(snap):
        return True
    if meta.get("weights") and not _has_real_weights(snap):
        return True
    if meta.get("source") == "hf_small" and not _has_real_weights(snap):
        return True
    if _is_tiny_stub(snap) and (
        "/" in mid
        or any(
            mid.startswith(p) or snap.name.startswith(p.replace("/", "__"))
            for p in (
                "moonshotai",
                "Qwen",
                "deepseek",
                "zai-org",
                "mistralai",
                "meta-llama",
                "HuggingFaceTB",
                "TinyLlama",
                "microsoft",
                "google",
            )
        )
    ):
        return True
    return False


def _dense_engine_supported(snap: Path) -> bool:
    """True when windhover-engine dense/Windhover path can load this SNAP
    (Qwen2/3, Llama, Mistral, Gemma2/3, Phi-3)."""
    cfg_path = snap / "config.json"
    if not cfg_path.is_file():
        return False
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    # MoE packs use engine.c (same int4+IDOT family), not dense/windhover
    if cfg.get("n_routed_experts") or cfg.get("num_experts") or cfg.get("num_local_experts"):
        return False
    arches = " ".join(str(a) for a in (cfg.get("architectures") or []))
    if any(
        x in arches
        for x in (
            "MixtralForCausalLM",
            "Qwen2MoeForCausalLM",
            "Qwen3MoeForCausalLM",
        )
    ):
        return False
    mt = str(cfg.get("model_type") or "").lower()
    if mt in ("qwen2", "qwen3", "llama", "mistral", "gemma2", "gemma3", "phi3"):
        return True
    return any(
        x in arches
        for x in (
            "Qwen2ForCausalLM",
            "Qwen3ForCausalLM",
            "LlamaForCausalLM",
            "MistralForCausalLM",
            "Gemma2ForCausalLM",
            "Gemma3ForCausalLM",
            "Phi3ForCausalLM",
        )
    )


def _has_kpk(snap: Path) -> bool:
    """True when a Windhover KPK pack exists (snap/kpk or snap itself)."""
    for d in (snap / "kpk", snap):
        kj = d / "kestrel.json"
        if kj.is_file():
            try:
                if "windhover" in json.loads(kj.read_text(encoding="utf-8")):
                    return True
            except Exception:
                pass
    return False


def _windhover_supported(snap: Path) -> bool:
    """True when tools/kestrel_pack.py can convert this pack for the
    Windhover runtime (dense qwen2/qwen3/llama/mistral/gemma2/gemma3/phi3)."""
    cfg_path = snap / "config.json"
    if not cfg_path.is_file():
        return False
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    if cfg.get("n_routed_experts") or cfg.get("num_experts") or cfg.get("num_local_experts"):
        return False
    mt = str(cfg.get("model_type") or "").lower()
    return mt in ("qwen2", "qwen3", "llama", "mistral", "gemma2", "gemma3", "phi3")


def _kpk_convert(snap: Path, job_id: str | None = None) -> bool:
    """Run the one-time Windhover convert (quant + calibrate + AWQ). ~1-2 min/GB."""
    tool = ROOT / "tools" / "kestrel_pack.py"
    if not tool.is_file() or os.environ.get("WINDHOVER_NO_KPK") or os.environ.get("KESTREL_NO_KPK"):
        return False
    if _has_kpk(snap):
        return True
    if job_id:
        _job_set(job_id, status="running", pct=98, message="Windhover convert (int4-g64 + calibrate)…")
    print("running Windhover convert (one-time quantize + calibrate)…")
    rc = subprocess.call([sys.executable, str(tool), "--snap", str(snap)])
    if rc != 0:
        # calibration needs torch; fall back to plain quant pack
        rc = subprocess.call(
            [sys.executable, str(tool), "--snap", str(snap), "--no-calib", "--no-awq"]
        )
    return rc == 0 and _has_kpk(snap)


def _chat_mode(snap: Path) -> str:
    """Return preview | engine | engine-oracle | blocked."""
    meta = _snap_meta(snap)
    mid = str(meta.get("id") or "").replace("__", "/")
    chat = meta.get("chat")
    if mid.endswith("chat-preview") or meta.get("source") == "preview":
        return "preview"
    if _is_impostor_pack(snap):
        return "blocked"
    if chat == "preview":
        # Real small-model downloads: prefer the engine when supported
        if meta.get("weights") and _has_real_weights(snap):
            if _has_kpk(snap) or _dense_engine_supported(snap):
                return "engine"
            return "preview"
        return "blocked"
    if chat == "engine-oracle" or mid.startswith(("windhover/glm-tiny", "kestrel/glm-tiny")):
        return "engine-oracle"
    if meta.get("runner") and mid.startswith(("windhover/", "kestrel/")):
        return "engine-oracle"
    if _is_tiny_stub(snap) and not mid.startswith(("windhover/", "kestrel/")):
        return "blocked"
    return "engine"


def _format_engine_prompt(snap: Path, messages: list | None, flat_prompt: str) -> str:
    """Apply HF chat template when available so dense/engine packs get instruct formatting."""
    if messages:
        try:
            from transformers import AutoTokenizer

            tok = AutoTokenizer.from_pretrained(str(snap), trust_remote_code=True)
            chat = []
            for m in messages:
                role = m.get("role") or "user"
                content = (m.get("content") or "").strip()
                if content and role in ("user", "assistant", "system"):
                    chat.append({"role": role, "content": content})
            if chat and hasattr(tok, "apply_chat_template") and tok.chat_template:
                return tok.apply_chat_template(chat, tokenize=False, add_generation_prompt=True)
        except Exception as e:
            sys.stderr.write(f"[windhover] chat template fallback: {e}\n")
    if messages:
        parts = []
        for m in messages:
            role = m.get("role") or "user"
            content = (m.get("content") or "").strip()
            if content:
                parts.append(f"{role}: {content}")
        if parts:
            return "\n".join(parts) + "\nassistant:"
    return flat_prompt


def _preview_load_src(snap: Path | None, meta: dict, repo: str) -> str:
    """Prefer a real local HF checkout when weights were downloaded."""
    if snap and meta.get("weights"):
        if (snap / "config.json").is_file() and (
            any(snap.glob("*.safetensors")) or any(snap.glob("model*.bin")) or (snap / "pytorch_model.bin").is_file()
        ):
            return str(snap)
    return repo


def _preview_chat(
    messages: list,
    max_tokens: int,
    temperature: float,
    *,
    snap: Path | None = None,
) -> tuple[str, dict]:
    """On-device transformers chat for Chat Preview and Mac-16GB small HF models."""
    import time

    t0 = time.perf_counter()
    meta = _snap_meta(snap) if snap else {}
    repo = meta.get("preview_repo") or meta.get("hf_repo") or PREVIEW_REPO
    selected = meta.get("id") or "windhover/chat-preview"
    display = meta.get("name") or selected
    load_src = _preview_load_src(snap, meta, repo)
    try:
        import torch
        from transformers import AutoModelForCausalLM, AutoTokenizer

        if load_src not in _PREVIEW_PIPES:
            sys.stderr.write(f"[windhover] loading small model: {load_src}…\n")
            tok = AutoTokenizer.from_pretrained(load_src, trust_remote_code=True)
            dtype = torch.float16 if getattr(torch.backends, "mps", None) and torch.backends.mps.is_available() else torch.float32
            model = AutoModelForCausalLM.from_pretrained(
                load_src,
                torch_dtype=dtype,
                trust_remote_code=True,
                low_cpu_mem_usage=True,
            )
            if getattr(torch.backends, "mps", None) and torch.backends.mps.is_available():
                model = model.to("mps")
            model.eval()
            _PREVIEW_PIPES[load_src] = (tok, model)
            sys.stderr.write(f"[windhover] small model ready: {load_src}\n")
        tok, model = _PREVIEW_PIPES[load_src]
        if selected == "windhover/chat-preview":
            system = (
                "You are Windhover Chat Preview, a small on-device instruct model "
                f"({repo}). You are NOT Kimi, Qwen, DeepSeek, GLM, Llama, or any "
                "frontier MoE. Be honest if asked which model you are. "
                "Answer clearly with Markdown when helpful."
            )
        else:
            system = (
                f"You are {display}, running locally in Windhover from {repo}. "
                "Be honest about which model you are. Answer clearly with Markdown when helpful."
            )
        chat = [{"role": "system", "content": system}]
        for m in messages:
            role = m.get("role") or "user"
            content = (m.get("content") or "").strip()
            if content and role in ("user", "assistant", "system"):
                chat.append({"role": role, "content": content})
        if not any(m["role"] == "user" for m in chat):
            return "empty prompt", {}
        if hasattr(tok, "apply_chat_template") and tok.chat_template:
            prompt = tok.apply_chat_template(chat, tokenize=False, add_generation_prompt=True)
        else:
            prompt = "\n".join(f"{m['role']}: {m['content']}" for m in chat) + "\nassistant:"
        inputs = tok(prompt, return_tensors="pt")
        device = next(model.parameters()).device
        inputs = {k: v.to(device) for k, v in inputs.items()}
        gen_kwargs = {
            "max_new_tokens": max(16, min(int(max_tokens), 512)),
            "pad_token_id": tok.eos_token_id,
        }
        if float(temperature) > 0:
            gen_kwargs.update(do_sample=True, temperature=max(float(temperature), 0.05))
        else:
            gen_kwargs["do_sample"] = False
        with torch.inference_mode():
            out = model.generate(**inputs, **gen_kwargs)
        new_tokens = out[0][inputs["input_ids"].shape[-1] :]
        text = _clean_chat_text(tok.decode(new_tokens, skip_special_tokens=True))
        elapsed = max(time.perf_counter() - t0, 1e-6)
        ntok = int(new_tokens.numel()) if hasattr(new_tokens, "numel") else len(new_tokens)
        stats = {
            "rss_mb": round(_rss_mb(), 1),
            "latency_ms": round(elapsed * 1000, 1),
            "tokens_per_sec": round(ntok / elapsed, 2),
            "completion_tokens": ntok,
            "backend": "preview",
            "selected_model": selected,
            "preview_model": repo,
            "family": meta.get("family") or "kestrel",
            "engine": str(ENGINE_BIN),
        }
        _LAST_STATS.update(stats)
        return text or "(empty preview generation)", stats
    except Exception as e:
        err = f"{type(e).__name__}: {e}"
        sys.stderr.write(f"[windhover] preview chat failed: {err}\n")
        return (
            "Small-model chat failed to load. Run: pip install transformers torch\n"
            f"Details: {err}",
            {"backend": "preview", "error": err, "selected_model": selected, "preview_model": repo},
        )


def _engine_chat(
    snap: Path,
    prompt: str,
    max_tokens: int,
    temperature: float,
    *,
    messages: list | None = None,
    on_delta=None,
) -> tuple[str, dict]:
    import time

    t0 = time.perf_counter()
    formatted = _format_engine_prompt(snap, messages, prompt)
    env = _engine_env(snap, None)
    env["PROMPT"] = formatted
    env["COLI_PROMPT"] = formatted
    env["NGEN"] = str(max_tokens)
    env["TEMP"] = str(temperature)
    env["QUIET"] = "1"
    env["DRAFT"] = "0"
    env["WH_JSON_STATS"] = "1"

    wh_stats: dict = {}

    def _dec(b: bytes) -> str:
        return (b or b"").decode("utf-8", errors="replace").strip()

    if on_delta is None:
        p = subprocess.run(
            [str(ENGINE_BIN), "64", "4", "4"],
            cwd=str(ENGINE_DIR),
            env=env,
            capture_output=True,
        )
        raw_out, err, rc = p.stdout, _dec(p.stderr), p.returncode
    else:
        # stream stdout bytes to the client as they arrive
        proc = subprocess.Popen(
            [str(ENGINE_BIN), "64", "4", "4"],
            cwd=str(ENGINE_DIR),
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
        chunks: list[bytes] = []
        pending = b""
        while True:
            b = proc.stdout.read(64)
            if not b:
                break
            chunks.append(b)
            pending += b
            # hold back a partial UTF-8 tail and anything after the stats marker
            if b"@@WH_STATS@@" in pending:
                emit, _, _ = pending.partition(b"@@WH_STATS@@")
                pending = b""
            else:
                emit, pending = pending, b""
                for back in range(1, min(4, len(emit)) + 1):
                    if emit[-back] & 0xC0 == 0xC0:  # UTF-8 lead byte in the tail
                        pending = emit[-back:]
                        emit = emit[:-back]
                        break
            if emit:
                try:
                    on_delta(_clean_chat_text(emit.decode("utf-8", errors="replace"), soft=True))
                except Exception:
                    proc.kill()
                    raise
        raw_out = b"".join(chunks)
        err = _dec(proc.stderr.read())
        rc = proc.wait()

    text = _dec(raw_out)
    if "@@WH_STATS@@" in text:
        text, _, tail = text.partition("@@WH_STATS@@")
        try:
            wh_stats = json.loads(tail.strip().splitlines()[0])
        except Exception:
            wh_stats = {}
    text = _clean_chat_text(text)

    class _P:  # keep the legacy field names below working
        returncode = rc
    p = _P()
    elapsed = max(time.perf_counter() - t0, 1e-6)
    meta = _snap_meta(snap)
    if p.returncode != 0 and not text:
        text = err or f"engine exited {p.returncode}"
    elif not text and err:
        if "tokenizer" in err.lower() or "No such file" in err:
            text = "Model pack incomplete — re-install from Library."
        else:
            text = err.splitlines()[-1] if err else "(empty generation)"
    bad = sum(
        1
        for ch in text
        if ch == "\ufffd" or (ord(ch) < 32 and ch not in "\n\t") or ord(ch) > 126
    )
    if text and bad > max(3, len(text) // 3):
        text = (
            "windhover-engine ran this pack, but the weights are a random oracle fixture — "
            "not coherent English. For conversation, install **Windhover Chat Preview**. "
            "For a real MoE, download full HF weights and convert."
        )
    ntok = int(wh_stats.get("tokens") or max(1, len((text or "").split())))
    stats = {
        "rss_mb": round(_rss_mb(), 1),
        "latency_ms": round(elapsed * 1000, 1),
        "tokens_per_sec": wh_stats.get("decode_tok_s") or round(ntok / elapsed, 2),
        "completion_tokens": ntok,
        "backend": "windhover-engine",
        "selected_model": meta.get("id") or snap.name,
        "preview_model": None,
        "family": meta.get("family"),
        "engine": str(ENGINE_BIN),
    }
    if wh_stats:
        stats["windhover"] = {
            "decode_tok_s": wh_stats.get("decode_tok_s"),
            "prefill_tok_s": wh_stats.get("prefill_tok_s"),
            "footprint_gb": wh_stats.get("footprint_gb"),
            "sparsity_pct": wh_stats.get("sparsity_pct"),
            "bytes_per_tok": wh_stats.get("bytes_per_tok"),
            "au_hit_pct": wh_stats.get("au_hit_pct"),
            "forwards": wh_stats.get("forwards"),
        }
    _LAST_STATS.update(stats)
    return text, stats


def _agent_run(
    *,
    snap: Path,
    workspace: Path,
    prompt: str,
    max_steps: int = 8,
    max_tokens: int = 256,
    temperature: float = 0.2,
) -> dict:
    """Host-side tool loop: local LLM proposes tools; we execute under workspace."""
    if _agent_ws is None:
        return {"ok": False, "error": "agent_workspace module missing"}
    root = workspace.resolve()
    if not root.is_dir():
        return {"ok": False, "error": f"workspace not a directory: {root}"}
    mode = _chat_mode(snap)
    if mode == "blocked":
        return {"ok": False, "error": "model is a fake stub — uninstall it"}
    if mode not in ("preview", "engine", "engine-oracle"):
        return {"ok": False, "error": f"model not chat-capable (mode={mode})"}

    steps: list[dict] = []
    tool_results: list[dict] = []
    final_summary = ""
    last_text = ""
    wrote_ok = False
    edit_intent = any(
        w in prompt.lower()
        for w in (
            "edit",
            "change",
            "add",
            "insert",
            "fix",
            "write",
            "create",
            "update",
            "refactor",
            "docstring",
            "str_replace",
            "implement",
        )
    )

    for step_i in range(max(1, min(int(max_steps), 12))):
        messages = _agent_ws.build_agent_messages(
            user_prompt=prompt,
            workspace_root=str(root),
            tool_results=tool_results or None,
        )
        if edit_intent and not wrote_ok and step_i > 0:
            messages.append(
                {
                    "role": "user",
                    "content": (
                        "You have not successfully written a file yet. "
                        "You MUST call str_replace or write_file before finish. "
                        "Do not call finish until a write tool returns ok:true."
                    ),
                }
            )
        if mode == "preview":
            text, stats = _preview_chat(messages, max_tokens, temperature, snap=snap)
        else:
            flat = "\n".join(f"{m['role']}: {m['content']}" for m in messages)
            text, stats = _engine_chat(
                snap, flat[-4000:], max_tokens, temperature, messages=messages
            )
        last_text = text or ""
        calls = _agent_ws.parse_tool_calls(last_text)
        step: dict = {
            "step": step_i + 1,
            "assistant": last_text[:4000],
            "tool_calls": calls,
            "tool_results": [],
            "stats": {
                "tokens_per_sec": stats.get("tokens_per_sec"),
                "latency_ms": stats.get("latency_ms"),
                "backend": stats.get("backend"),
            },
        }
        if not calls:
            if edit_intent and not wrote_ok and step_i + 1 < max_steps:
                tool_results = [
                    {
                        "ok": False,
                        "error": "No tool call parsed. Emit a ```tool JSON block (str_replace or write_file).",
                    }
                ]
                step["tool_results"] = tool_results
                steps.append(step)
                continue
            final_summary = last_text.strip() or "(no tool calls; empty reply)"
            step["done"] = True
            steps.append(step)
            break

        tool_results = []
        finished = False
        for call in calls:
            name = (call.get("name") or call.get("tool") or "").strip()
            if name == "finish" and edit_intent and not wrote_ok:
                result = {
                    "tool": "finish",
                    "ok": False,
                    "error": "Refused finish: no successful write yet. Call str_replace or write_file first.",
                }
            else:
                result = _agent_ws.run_tool(root, call)
            tool_results.append(result)
            step["tool_results"].append(result)
            if name in ("write_file", "str_replace") and result.get("ok"):
                wrote_ok = True
            if name == "finish" and result.get("ok"):
                final_summary = result.get("summary") or "done"
                finished = True
        steps.append(step)
        if finished:
            break

    return {
        "ok": True,
        "workspace": str(root),
        "model": _snap_meta(snap).get("id") or snap.name,
        "steps": steps,
        "summary": final_summary or last_text[:2000],
        "step_count": len(steps),
        "wrote": wrote_ok,
    }


def _ensure_nofile() -> None:
    if sys.platform == "win32":
        return
    try:
        import resource

        soft, hard = resource.getrlimit(resource.RLIMIT_NOFILE)
        want = min(65536 if hard == resource.RLIM_INFINITY else hard, 65536)
        if soft < want:
            resource.setrlimit(resource.RLIMIT_NOFILE, (want, hard))
    except (ImportError, ValueError, OSError):
        pass


