def load_catalog() -> list[dict]:
    if not CATALOG_PATH.is_file():
        return []
    try:
        models = json.loads(CATALOG_PATH.read_text(encoding="utf-8")).get("models", [])
    except (OSError, UnicodeError, json.JSONDecodeError) as e:
        sys.stderr.write(f"[windhover] catalog load failed: {e}\n")
        return []
    # HF models only — never surface preview/fixture demos as installable engines.
    out = []
    for m in models:
        mid = str(m.get("id") or "")
        src = m.get("source")
        if src in ("preview", "fixture"):
            continue
        if mid.endswith("chat-preview") or "glm-tiny" in mid:
            continue
        if not (m.get("hf_repo") or m.get("preview_repo")):
            continue
        if not m.get("hf_repo") and m.get("preview_repo"):
            m = {**m, "hf_repo": m.get("preview_repo")}
        out.append(m)
    return out


def _is_demo_pack(snap: Path) -> bool:
    """Chat Preview / oracle fixture packs — not real HF engine installs."""
    meta = _snap_meta(snap)
    mid = str(meta.get("id") or snap.name).replace("__", "/")
    if mid.endswith("chat-preview") or "glm-tiny" in mid:
        return True
    if meta.get("source") in ("preview", "fixture"):
        return True
    if meta.get("chat") == "engine-oracle":
        return True
    # Marker-only preview with no weights on disk
    if meta.get("chat") == "preview" and not _has_real_weights(snap) and not meta.get("weights"):
        return True
    return False


def _write_kestrel_meta(dest: Path, mid: str, entry: dict, **extra) -> None:
    meta = {
        "id": mid,
        "name": entry.get("name", mid),
        "family": entry.get("family"),
        "hf_repo": entry.get("hf_repo"),
        "engine": entry.get("engine") or "windhover-engine",
        "chat": entry.get("chat"),
        "preview_repo": entry.get("preview_repo"),
        "ready": True,
        "runner": False,
    }
    meta.update(extra)
    (dest / "kestrel.json").write_text(json.dumps(meta, indent=2) + "\n")


def _install_fixture(mid: str, entry: dict, dest: Path) -> int:
    """Install only explicit demo fixtures (glm_tiny), never as a fake frontier MoE."""
    if entry.get("source") != "fixture":
        print("refusing fixture install for non-fixture catalog entry", file=sys.stderr)
        return 1
    fixture = entry.get("fixture") or "glm_tiny"
    src = ENGINE_DIR / "fixtures" / fixture
    if not src.is_dir():
        print(f"engine fixture missing: {src}", file=sys.stderr)
        return 1
    if dest.exists():
        shutil.rmtree(dest)
    shutil.copytree(src, dest)
    _write_kestrel_meta(dest, mid, entry, runner=False, chat=entry.get("chat") or "engine-oracle")
    print(f"done (engine demo fixture -> {dest})")
    return 0


def _install_preview(mid: str, entry: dict, dest: Path) -> int:
    """Mark Chat Preview installed (weights load from HF cache on first message)."""
    if dest.exists():
        shutil.rmtree(dest)
    dest.mkdir(parents=True, exist_ok=True)
    _write_kestrel_meta(
        dest,
        mid,
        entry,
        runner=False,
        chat="preview",
        preview_repo=entry.get("preview_repo") or PREVIEW_REPO,
    )
    (dest / "README.txt").write_text(
        "Windhover Chat Preview — uses Hugging Face cache for "
        f"{entry.get('preview_repo') or PREVIEW_REPO} on first chat.\n"
        "This is NOT Kimi, Qwen, or any frontier MoE.\n"
    )
    print(f"done (chat preview -> {dest})")
    return 0


def _resolve_model_dir(model_id: str | None, fallback: Path | None) -> Path | None:
    """Map OpenAI-style model id / catalog id / folder name to an installed SNAP dir.

    Returns fallback only for empty/auto ids — never substitutes another catalog model.
    """
    if not model_id or model_id in ("kestrel", "default", "auto"):
        return fallback
    key = model_id.replace("/", "__")
    for p in (MODELS_DIR / key, MODELS_DIR / model_id):
        if not p.is_dir():
            continue
        if (p / "kestrel.json").is_file() or (p / "model.safetensors").is_file() or any(
            p.glob("*.safetensors")
        ):
            return p
    for meta in _list_installed():
        path = Path(meta.get("path") or "")
        if not path.is_dir():
            continue
        mid = str(meta.get("id") or "")
        if mid == model_id or mid.replace("/", "__") == key or path.name == key:
            return path
    # Do NOT fall back to another installed model — that caused K2.6 → Preview lies.
    return None


def _hf_snapshot_download(
    repo: str,
    dest: Path,
    *,
    revision: str | None = None,
    job_id: str | None = None,
    expected_bytes: float = 0,
) -> None:
    """Download a full HF repo into dest with optional job progress updates."""
    _ensure_hf_hub()
    from huggingface_hub import snapshot_download

    stop = threading.Event()

    def monitor() -> None:
        while not stop.wait(0.45):
            if not job_id:
                continue
            cur = float(_dir_bytes(dest))
            if expected_bytes > 0:
                pct = int(min(95, max(3, 3 + 92 * (cur / expected_bytes))))
                msg = f"Downloading {_fmt_bytes(cur)} / {_fmt_bytes(expected_bytes)}"
            else:
                pct = min(90, 5 + int(cur / (50 * 1e6)))
                msg = f"Downloading {_fmt_bytes(cur)}"
            _job_set(job_id, status="running", pct=pct, bytes=cur, message=msg)

    try:
        if job_id:
            _job_set(
                job_id,
                status="running",
                pct=1,
                bytes=0,
                message=f"Connecting to Hugging Face ({repo})...",
            )
        mon = threading.Thread(target=monitor, daemon=True)
        mon.start()
        try:
            # Keep HF blob cache under ~/.kestrel so Library downloads don't
            # silently fill ~/.cache and double-consume disk on copy.
            cache_dir = MODELS_DIR / ".hf-cache"
            cache_dir.mkdir(parents=True, exist_ok=True)
            # Re-wrap stdio right before HF I/O — libraries may reset handlers.
            _configure_stdio_utf8()
            snapshot_download(
                repo_id=repo,
                local_dir=str(dest),
                cache_dir=str(cache_dir),
                revision=revision,
                max_workers=4,
            )
        finally:
            stop.set()
            mon.join(timeout=1.0)
        if job_id:
            cur = float(_dir_bytes(dest))
            _job_set(
                job_id,
                status="running",
                pct=97,
                bytes=cur,
                message=f"Verifying download ({_fmt_bytes(cur)})...",
            )
    except OSError as e:
        if getattr(e, "errno", None) == 28:
            raise OSError(
                28,
                "No space left on device while downloading. Free disk space "
                "(Windhover stores weights under ~/.windhover/models) and retry.",
            ) from e
        raise


def cmd_pull(ns: argparse.Namespace) -> int:
    # Re-assert safe stdio: Windows pull threads/sidecars can inherit cp1252 handles.
    _configure_stdio_utf8()
    catalog = {m["id"]: m for m in load_catalog()}
    mid = ns.model_id
    job_id = getattr(ns, "job_id", None)
    if mid not in catalog:
        print(f"unknown model id {mid!r}. Known: {', '.join(catalog) or '(empty catalog)'}", file=sys.stderr)
        if job_id:
            _job_set(job_id, status="error", error=f"unknown model id {mid}", pct=0)
        return 1
    entry = catalog[mid]
    dest = MODELS_DIR / mid.replace("/", "__")
    MODELS_DIR.mkdir(parents=True, exist_ok=True)
    print(f"pulling {mid} -> {dest}")

    # Demos removed from catalog — refuse if an old client still asks.
    if entry.get("source") in ("preview", "fixture") or mid.endswith("chat-preview") or "glm-tiny" in mid:
        err = (
            f"Refusing {mid}: Windhover only installs real Hugging Face models "
            "(no Chat Preview / oracle fixture packs)."
        )
        print(err, file=sys.stderr)
        if job_id:
            _job_set(job_id, status="error", error=err, pct=0)
        return 1

    try:
        size_gb = float(entry.get("size_gb") or 999)
    except (TypeError, ValueError):
        size_gb = 999.0
    is_small = (
        entry.get("source") == "hf_small"
        or entry.get("tier") == "mac16"
        or (size_gb <= 20 and entry.get("chat") == "preview" and bool(entry.get("hf_repo")))
    )

    want_weights = (
        bool(getattr(ns, "weights", False))
        or os.environ.get("WINDHOVER_PULL_WEIGHTS") or os.environ.get("KESTREL_PULL_WEIGHTS") == "1"
        or is_small
    )
    if not want_weights:
        size = entry.get("size_gb") or "?"
        err = (
            f"Refusing stub install for {mid}. "
            f"Needs a real Hugging Face download (~{size} GB). Pass weights=true."
        )
        print(err, file=sys.stderr)
        if job_id:
            _job_set(job_id, status="error", error=err, pct=0, needs_download=True)
        return 2

    repo = entry.get("hf_repo")
    if not repo:
        print("catalog entry missing hf_repo", file=sys.stderr)
        if job_id:
            _job_set(job_id, status="error", error="catalog entry missing hf_repo", pct=0)
        return 1

    expected = size_gb * 1e9
    if dest.exists():
        shutil.rmtree(dest)
    dest.mkdir(parents=True, exist_ok=True)

    try:
        print(f"downloading {repo} (~{size_gb} GB) via huggingface_hub...")
        _hf_snapshot_download(
            repo,
            dest,
            revision=entry.get("hf_revision"),
            job_id=job_id,
            expected_bytes=expected,
        )
    except Exception as e:
        err = f"{type(e).__name__}: {e}"
        print(f"download failed: {err}", file=sys.stderr)
        if dest.exists():
            shutil.rmtree(dest, ignore_errors=True)
        if job_id:
            _job_set(job_id, status="error", error=err, pct=0)
        return 1

    # Refuse to mark incomplete/empty downloads as installed
    min_bytes = max(30_000_000, int(expected * 0.05)) if expected > 0 else 30_000_000
    got = _weight_bytes(dest)
    if got < min_bytes:
        err = (
            f"Download incomplete for {mid}: only {_fmt_bytes(got)} of weights "
            f"(expected ~{_fmt_bytes(expected)}). Check network / HF auth and retry."
        )
        print(err, file=sys.stderr)
        shutil.rmtree(dest, ignore_errors=True)
        if job_id:
            _job_set(job_id, status="error", error=err, pct=0, bytes=got)
        return 1

    if entry.get("convert") == "fp8_to_int4":
        convert = C_DIR / "tools" / "convert_fp8_to_int4.py"
        if convert.is_file():
            if job_id:
                _job_set(job_id, status="running", pct=98, message="Converting FP8->int4...")
            print("running FP8->int4 convert (may take a long time)...")
            out = dest / "int4"
            out.mkdir(exist_ok=True)
            rc = subprocess.call(
                [sys.executable, str(convert), "--indir", str(dest), "--outdir", str(out)]
            )
            if rc == 0:
                dest = out
    elif _windhover_supported(dest):
        # Dense pack → one-time Windhover KPK convert (mmap int4-g64 + calibration)
        if not _kpk_convert(dest, job_id):
            # Qwen/Llama/Mistral can still chat via dense load-time quant.
            # Phi/Gemma require a KPK — fail install with a clear error.
            if not _dense_loadtime_ok(dest):
                err = (
                    f"Engine pack convert failed for {mid}: "
                    f"{_LAST_CONVERT_ERROR or 'unknown error'}. "
                    "Retry Install from Library (needs a few minutes after download)."
                )
                print(err, file=sys.stderr)
                if job_id:
                    _job_set(job_id, status="error", error=err, pct=0)
                return 1

    # Prefer catalog intent; upgrade preview→engine when the Windhover pack or
    # dense layout matches. Frontier MoEs (GLM/Kimi/…) stay on engine.c.
    cat_chat = entry.get("chat")
    if _has_kpk(dest):
        chat_mode = "engine"
    elif cat_chat in ("engine", "engine-oracle"):
        chat_mode = cat_chat
    elif _dense_engine_supported(dest):
        chat_mode = "engine"
    elif is_small or cat_chat == "preview":
        chat_mode = "preview"
    else:
        chat_mode = "engine"
    eng = (
        "windhover-engine"
        if chat_mode in ("engine", "engine-oracle")
        else entry.get("engine") or "preview"
    )
    _write_kestrel_meta(
        dest,
        mid,
        entry,
        runner=False,
        chat=chat_mode,
        weights=True,
        preview_repo=entry.get("preview_repo") or repo,
        tier=entry.get("tier"),
        source=entry.get("source"),
        size_bytes=_dir_bytes(dest),
        weight_bytes=got,
        engine=eng,
    )
    print(f"ready: {dest} ({_fmt_bytes(_dir_bytes(dest))})")
    if job_id:
        _job_set(
            job_id,
            status="done",
            pct=100,
            bytes=float(_dir_bytes(dest)),
            message=f"Installed {_fmt_bytes(_dir_bytes(dest))}",
            path=str(dest),
        )
    return 0


def cmd_uninstall(ns: argparse.Namespace) -> int:
    mid = (ns.model_id or "").strip()
    if not mid:
        print("missing model id", file=sys.stderr)
        return 1
    keys = {
        mid,
        mid.replace("/", "__"),
        mid.replace("__", "/"),
        Path(mid).name,
        Path(mid.replace("__", "/")).name,
    }
    # Also match by catalog name stem
    stem = mid.split("/")[-1] if "/" in mid or "__" in mid else mid
    keys.add(stem)
    candidates: list[Path] = []
    for k in keys:
        if k:
            candidates.append(MODELS_DIR / k)
    for meta in _list_installed():
        path = Path(meta.get("path") or "")
        mid_m = str(meta.get("id") or "")
        name_m = str(meta.get("name") or "")
        if (
            mid_m in keys
            or mid_m.replace("/", "__") in keys
            or mid_m.replace("__", "/") in keys
            or path.name in keys
            or path.name.replace("__", "/") in keys
            or stem in mid_m
            or stem in path.name
            or (name_m and name_m.lower() == mid.lower())
        ):
            candidates.append(path)
    removed: list[str] = []
    seen: set[str] = set()
    models_root = MODELS_DIR.resolve()
    for dest in candidates:
        try:
            resolved = dest.resolve()
        except OSError:
            continue
        if str(resolved) in seen:
            continue
        seen.add(str(resolved))
        if not resolved.is_dir():
            continue
        if resolved != models_root and not str(resolved).startswith(str(models_root) + os.sep):
            continue
        # Drop cached transformers pipes for this pack
        meta = _snap_meta(resolved)
        for key in list(_PREVIEW_PIPES.keys()):
            if str(resolved) in key or str(meta.get("preview_repo") or "") in key:
                _PREVIEW_PIPES.pop(key, None)
        shutil.rmtree(resolved)
        print(f"uninstalled {resolved}")
        removed.append(str(resolved))
    if not removed:
        print(f"not installed: {mid}", file=sys.stderr)
        return 1
    return 0


def cmd_purge_impostors(_: argparse.Namespace) -> int:
    """Remove fake stubs and Chat Preview / oracle demo packs."""
    n = 0
    MODELS_DIR.mkdir(parents=True, exist_ok=True)
    for path in sorted(MODELS_DIR.iterdir()) if MODELS_DIR.is_dir() else []:
        if not path.is_dir() or path.name.startswith("."):
            continue
        mid = path.name.replace("__", "/")
        if mid.startswith("ollama/"):
            continue
        kill = _is_impostor_pack(path) or _is_demo_pack(path)
        if not kill:
            continue
        kind = "demo" if _is_demo_pack(path) else "impostor"
        print(f"purging {kind} pack: {mid} -> {path}")
        shutil.rmtree(path)
        n += 1
    print(f"purged {n} fake/demo pack(s)")
    return 0


def _is_ollama_model_id(model_id: str | None) -> bool:
    return bool(model_id) and str(model_id).startswith("ollama/")


def _ollama_tag(model_id: str) -> str:
    """ollama/gemma4:latest → gemma4:latest"""
    return str(model_id)[len("ollama/") :].strip()


def _ollama_url(path: str) -> str:
    if not path.startswith("/"):
        path = "/" + path
    return f"{OLLAMA_HOST}{path}"


def _ollama_reachable(timeout: float = 0.6) -> bool:
    try:
        req = urllib.request.Request(_ollama_url("/api/tags"), method="GET")
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return 200 <= getattr(resp, "status", 200) < 300
    except Exception:
        return False


def _ollama_list_models(timeout: float = 1.5) -> list[dict]:
    """Return virtual installed entries for models already pulled into Ollama."""
    try:
        req = urllib.request.Request(_ollama_url("/api/tags"), method="GET")
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = json.loads(resp.read().decode("utf-8", errors="replace"))
    except Exception:
        return []
    out: list[dict] = []
    for m in data.get("models") or []:
        name = str(m.get("name") or m.get("model") or "").strip()
        if not name:
            continue
        size = int(m.get("size") or 0)
        details = m.get("details") or {}
        out.append(
            {
                "id": f"ollama/{name}",
                "name": name,
                "path": None,
                "ready": True,
                "engine": "ollama",
                "source": "ollama",
                "backend": "ollama",
                "chat": "ollama",
                "chat_mode": "ollama",
                "chat_ok": True,
                "impostor": False,
                "has_weights": True,
                "size_bytes": size,
                "weight_bytes": size,
                "family": "ollama",
                "description": f"Local Ollama model ({name})",
                "ollama_digest": m.get("digest"),
                "ollama_modified": m.get("modified_at") or m.get("modified"),
                "parameter_size": details.get("parameter_size"),
                "quantization": details.get("quantization_level"),
            }
        )
    out.sort(key=lambda x: str(x.get("id") or ""))
    return out


def _ollama_chat(
    messages: list,
    max_tokens: int,
    temperature: float,
    *,
    model_tag: str,
) -> tuple[str, dict]:
    """Proxy chat to the local Ollama OpenAI-compatible API."""
    t0 = time.time()
    clean_msgs = [
        {"role": m.get("role") or "user", "content": m.get("content") or ""}
        for m in messages
        if (m.get("content") or "").strip() or (m.get("role") in ("assistant", "system"))
    ]
    text = ""
    err: str | None = None
    completion_tokens = 0
    attempts = (
        (
            "/v1/chat/completions",
            {
                "model": model_tag,
                "messages": clean_msgs,
                "stream": False,
                "temperature": float(temperature),
                "max_tokens": int(max_tokens),
            },
        ),
        (
            "/api/chat",
            {
                "model": model_tag,
                "messages": clean_msgs,
                "stream": False,
                "options": {
                    "temperature": float(temperature),
                    "num_predict": int(max_tokens),
                },
            },
        ),
    )
    for path, payload in attempts:
        body = json.dumps(payload).encode("utf-8")
        try:
            req = urllib.request.Request(
                _ollama_url(path),
                data=body,
                headers={"Content-Type": "application/json"},
                method="POST",
            )
            with urllib.request.urlopen(req, timeout=600) as resp:
                raw = json.loads(resp.read().decode("utf-8", errors="replace"))
            if path.startswith("/v1/"):
                choices = raw.get("choices") or []
                if choices:
                    msg = choices[0].get("message") or {}
                    text = str(msg.get("content") or "")
                usage = raw.get("usage") or {}
                completion_tokens = int(usage.get("completion_tokens") or 0)
            else:
                msg = raw.get("message") or {}
                text = str(msg.get("content") or raw.get("response") or "")
                completion_tokens = int(raw.get("eval_count") or 0)
            err = None
            break
        except urllib.error.HTTPError as e:
            detail = ""
            try:
                detail = e.read().decode("utf-8", errors="replace")[:300]
            except Exception:
                pass
            err = f"Ollama HTTP {e.code}: {e.reason}" + (f" — {detail}" if detail else "")
        except Exception as e:
            err = f"{type(e).__name__}: {e}"
    dt = max(1e-6, time.time() - t0)
    if err and not text:
        stats = {
            "backend": "ollama",
            "error": err,
            "selected_model": f"ollama/{model_tag}",
            "preview_model": None,
            "latency_ms": round(dt * 1000, 1),
            "tokens_per_sec": 0.0,
            "completion_tokens": 0,
            "rss_mb": round(_rss_mb(), 1),
            "engine": "ollama",
        }
        _LAST_STATS.update(stats)
        return f"(ollama error: {err})", stats
    ntok = completion_tokens if completion_tokens > 0 else max(1, len((text or "").split()))
    stats = {
        "backend": "ollama",
        "selected_model": f"ollama/{model_tag}",
        "preview_model": model_tag,
        "family": "ollama",
        "latency_ms": round(dt * 1000, 1),
        "tokens_per_sec": round(ntok / dt, 2),
        "completion_tokens": ntok,
        "rss_mb": round(_rss_mb(), 1),
        "engine": "ollama",
    }
    _LAST_STATS.update(stats)
    return _clean_chat_text(text) or "(empty ollama generation)", stats


def _list_installed() -> list[dict]:
    MODELS_DIR.mkdir(parents=True, exist_ok=True)
    out = []
    for p in sorted(MODELS_DIR.iterdir()) if MODELS_DIR.is_dir() else []:
        if not p.is_dir() or p.name.startswith("."):
            continue
        if _is_demo_pack(p):
            # Hide demos from the Library/Chat pickers (purge removes them on app start).
            continue
        meta = {
            "id": p.name,
            "path": str(p),
            "ready": True,
            "engine": "windhover-engine",
        }
        kj = p / "kestrel.json"
        if kj.is_file():
            try:
                meta.update(json.loads(kj.read_text(encoding="utf-8")))
            except json.JSONDecodeError:
                pass
        mode = _chat_mode(p)
        meta["chat_mode"] = mode
        has_kpk_files = _has_kpk(p) or (
            (p / "kpk").is_dir() and any((p / "kpk").glob("kpk-*.safetensors"))
        )
        incomplete = (not _has_real_weights(p)) and (not has_kpk_files)
        meta["incomplete"] = bool(incomplete)
        # Needs a one-time KPK convert before windhover-engine can load (Phi/Gemma).
        needs_prepare = (
            bool(_has_real_weights(p))
            and not _has_kpk(p)
            and not _dense_loadtime_ok(p)
            and _windhover_supported(p)
        )
        meta["needs_prepare"] = needs_prepare
        meta["engine_ready"] = bool(_has_kpk(p) or _dense_loadtime_ok(p) or mode == "preview")
        # Real HF engine packs, or transformers fallback only when real weights exist.
        meta["chat_ok"] = mode == "engine" or (mode == "preview" and _has_real_weights(p))
        # Partial / in-progress downloads are incomplete — not fake stubs.
        if incomplete:
            meta["impostor"] = bool(
                meta.get("impostor") is True
                or meta.get("runner") is True
                or _is_tiny_stub(p)
            )
        else:
            meta["impostor"] = mode == "blocked" or _is_impostor_pack(p)
        meta["size_bytes"] = _dir_bytes(p)
        meta["weight_bytes"] = _weight_bytes(p)
        meta["has_weights"] = _has_real_weights(p)
        if meta["impostor"] or incomplete:
            meta["chat_ok"] = False
            meta["ready"] = False
        if incomplete and not meta.get("description"):
            meta["description"] = "Incomplete download — reinstall from Library to fetch model weights."
        elif needs_prepare and not meta.get("description"):
            meta["description"] = (
                "Downloaded — first chat prepares windhover-engine weights (one-time convert)."
            )
        out.append(meta)
    # Virtual entries for models already installed in Ollama (no re-download).
    out.extend(_ollama_list_models())
    return out


def _serve_library_api(host: str, port: int, model: Path | None) -> int:
    app_dist = ROOT / "app" / "dist"
    app_public = ROOT / "app" / "public"

    class H(BaseHTTPRequestHandler):
        def log_message(self, fmt: str, *args) -> None:
            sys.stderr.write("[windhover] " + (fmt % args) + "\n")

        protocol_version = "HTTP/1.1"

        def _json(self, code: int, obj: object) -> None:
            body = json.dumps(obj, ensure_ascii=True).encode("utf-8")
            try:
                self.send_response(code)
                self.send_header("Content-Type", "application/json; charset=utf-8")
                self.send_header("Access-Control-Allow-Origin", "*")
                self.send_header("Connection", "close")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError):
                # Client (e.g. flaky Invoke-WebRequest) dropped mid-response.
                return

        def do_OPTIONS(self) -> None:
            self.send_response(204)
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Access-Control-Allow-Methods", "GET,POST,OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type")
            self.end_headers()

        def do_GET(self) -> None:
            parsed = urlparse(self.path)
            path = parsed.path
            qs = parse_qs(parsed.query)
            if path in ("/health", "/v1/health"):
                present = ENGINE_BIN.is_file()
                last_active = _LAST_STATS.get("engine_active")
                return self._json(
                    200,
                    {
                        "ok": True,
                        "version": _app_version(),
                        "engine": str(ENGINE_BIN),
                        "engine_present": present,
                        "engine_on": present,
                        "engine_active": bool(present) if last_active is None else bool(last_active and present),
                        "rss_mb": round(_rss_mb(), 1),
                        "stats": _LAST_STATS,
                        "ollama": {
                            "host": OLLAMA_HOST,
                            "reachable": _ollama_reachable(),
                        },
                    },
                )
            if path in ("/v1/update", "/api/update"):
                force = (qs.get("force") or ["0"])[0] in ("1", "true", "yes")
                return self._json(200, _check_app_update(force=force))
            if path == "/api/ollama/status":
                models = _ollama_list_models()
                return self._json(
                    200,
                    {
                        "ok": True,
                        "host": OLLAMA_HOST,
                        "reachable": bool(models) or _ollama_reachable(),
                        "models": [m.get("id") for m in models],
                        "count": len(models),
                    },
                )
            if path == "/v1/catalog":
                return self._json(200, {"models": load_catalog()})
            if path == "/v1/models" or path == "/api/installed":
                return self._json(200, {"data": _list_installed(), "object": "list"})
            if path in ("/api/stats", "/v1/stats"):
                ollama_models = _ollama_list_models()
                return self._json(
                    200,
                    {
                        "ok": True,
                        "rss_mb": round(_rss_mb(), 1),
                        "engine": str(ENGINE_BIN),
                        "engine_present": ENGINE_BIN.is_file(),
                        "models_dir": str(MODELS_DIR),
                        "installed": len(_list_installed()),
                        "last": _LAST_STATS,
                        "chat_preview": PREVIEW_REPO,
                        "ollama_host": OLLAMA_HOST,
                        "ollama_reachable": bool(ollama_models) or _ollama_reachable(),
                        "ollama_models": len(ollama_models),
                    },
                )
            if path in ("/api/jobs", "/api/pull/status"):
                job_id = (qs.get("id") or qs.get("job_id") or [None])[0]
                if not job_id:
                    return self._json(400, {"error": "missing job id"})
                job = _job_get(job_id)
                if not job:
                    return self._json(404, {"error": "unknown job", "job_id": job_id})
                return self._json(200, {"ok": True, **job})
            if path.startswith("/api/jobs/"):
                job_id = path[len("/api/jobs/") :].strip("/")
                job = _job_get(job_id)
                if not job:
                    return self._json(404, {"error": "unknown job", "job_id": job_id})
                return self._json(200, {"ok": True, **job})
            if path == "/api/workspace":
                root = _WORKSPACE.get("root")
                return self._json(
                    200,
                    {"ok": True, "root": root, "agent": _agent_ws is not None},
                )
            if path == "/api/workspace/tree":
                root_s = _WORKSPACE.get("root")
                if not root_s:
                    return self._json(400, {"ok": False, "error": "no workspace set — POST /api/workspace first"})
                if _agent_ws is None:
                    return self._json(500, {"ok": False, "error": "agent_workspace missing"})
                rel = (qs.get("path") or ["."])[0]
                try:
                    return self._json(200, _agent_ws.list_dir(Path(root_s), rel))
                except Exception as e:
                    return self._json(400, {"ok": False, "error": f"{type(e).__name__}: {e}"})
            if path == "/api/workspace/file":
                root_s = _WORKSPACE.get("root")
                if not root_s:
                    return self._json(400, {"ok": False, "error": "no workspace set"})
                if _agent_ws is None:
                    return self._json(500, {"ok": False, "error": "agent_workspace missing"})
                rel = (qs.get("path") or [None])[0]
                if not rel:
                    return self._json(400, {"ok": False, "error": "missing path"})
                try:
                    return self._json(200, _agent_ws.read_file(Path(root_s), rel))
                except Exception as e:
                    return self._json(400, {"ok": False, "error": f"{type(e).__name__}: {e}"})
            # static app
            root = app_dist if (app_dist.is_dir() and (app_dist / "index.html").is_file()) else app_public
            rel = "index.html" if path in ("/", "") else path.lstrip("/")
            fp = (root / rel).resolve()
            if path in ("/", "") and not fp.is_file():
                # built assets live under dist/; index must exist after npm run build
                self.send_error(404, "UI not built — run: cd app && npm install && npm run build")
                return
            if not str(fp).startswith(str(root.resolve())) or not fp.is_file():
                self.send_error(404)
                return
            data = fp.read_bytes()
            ctype = "text/html"
            if fp.suffix == ".js":
                ctype = "application/javascript"
            elif fp.suffix == ".css":
                ctype = "text/css"
            elif fp.suffix == ".json":
                ctype = "application/json"
            elif fp.suffix == ".svg":
                ctype = "image/svg+xml"
            self.send_response(200)
            self.send_header("Content-Type", ctype)
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        def do_POST(self) -> None:
            path = urlparse(self.path).path
            n = int(self.headers.get("Content-Length", "0"))
            raw = self.rfile.read(n) if n else b"{}"
            try:
                body = json.loads(raw.decode() or "{}")
            except json.JSONDecodeError:
                return self._json(400, {"error": "bad json"})
            if path in ("/v1/update/apply", "/api/update/apply"):
                result = _apply_app_update(body.get("download_url"))
                return self._json(200 if result.get("ok") else 500, result)
            if path in ("/v1/prepare", "/api/prepare"):
                mid = body.get("id") or body.get("model_id") or body.get("model")
                snap = _resolve_model_dir(mid, None) if mid else None
                if snap is None or not snap.is_dir():
                    return self._json(404, {"ok": False, "error": f"model not installed: {mid}"})
                if _has_kpk(snap) or _dense_loadtime_ok(snap):
                    return self._json(
                        200,
                        {"ok": True, "ready": True, "id": mid, "message": "Already engine-ready"},
                    )
                if not (_windhover_supported(snap) and _has_real_weights(snap)):
                    return self._json(
                        400,
                        {
                            "ok": False,
                            "error": "This model cannot be converted for windhover-engine.",
                            "id": mid,
                        },
                    )
                job_id = _start_prepare_job(snap)
                return self._json(
                    202,
                    {
                        "ok": True,
                        "ready": False,
                        "async": True,
                        "job_id": job_id,
                        "code": "engine_preparing",
                        "id": mid,
                        "message": "Converting weights for windhover-engine…",
                    },
                )
            if path == "/api/pull":
                mid = body.get("id") or body.get("model_id")
                if not mid:
                    return self._json(400, {"error": "missing id"})
                weights = bool(body.get("weights"))
                cat = {m["id"]: m for m in load_catalog()}
                entry = cat.get(mid) or {}
                # Marker / demo installs stay sync; real HF downloads are async with progress.
                quick = entry.get("source") in ("preview", "fixture")
                want_async = bool(body.get("async", not quick))
                if not want_async or quick:
                    rc = cmd_pull(argparse.Namespace(model_id=mid, weights=weights, job_id=None))
                    err = None
                    if rc == 2:
                        err = (
                            f"Refused stub install. {mid} needs a real HF download "
                            f"(~{entry.get('size_gb', '?')} GB). Pass weights=true after confirming."
                        )
                    return self._json(
                        200 if rc == 0 else 400 if rc == 2 else 500,
                        {"ok": rc == 0, "id": mid, "error": err, "needs_download": rc == 2, "async": False},
                    )
                job_id = str(uuid.uuid4())
                _job_set(
                    job_id,
                    status="queued",
                    pct=0,
                    bytes=0,
                    message="Queued…",
                    model_id=mid,
                    error=None,
                )

                def _run_job() -> None:
                    try:
                        rc = cmd_pull(
                            argparse.Namespace(model_id=mid, weights=weights, job_id=job_id)
                        )
                        job = _job_get(job_id) or {}
                        if rc == 0 and job.get("status") != "done":
                            _job_set(job_id, status="done", pct=100, message="Installed")
                        elif rc == 2:
                            _job_set(
                                job_id,
                                status="error",
                                pct=0,
                                needs_download=True,
                                error=(
                                    f"Refused stub install. {mid} needs a real HF download "
                                    f"(~{entry.get('size_gb', '?')} GB)."
                                ),
                            )
                        elif rc != 0 and job.get("status") != "error":
                            _job_set(job_id, status="error", error="download failed", pct=0)
                    except Exception as e:
                        _job_set(job_id, status="error", error=f"{type(e).__name__}: {e}", pct=0)

                threading.Thread(target=_run_job, daemon=True).start()
                return self._json(
                    200,
                    {
                        "ok": True,
                        "async": True,
                        "job_id": job_id,
                        "id": mid,
                        "size_gb": entry.get("size_gb"),
                    },
                )
            if path in ("/api/uninstall", "/api/delete"):
                mid = body.get("id") or body.get("model_id") or ""
                path_hint = body.get("path")
                if path_hint:
                    # Prefer explicit path when UI knows the install folder
                    try:
                        dest = Path(str(path_hint)).resolve()
                        models_root = MODELS_DIR.resolve()
                        if dest.is_dir() and str(dest).startswith(str(models_root) + os.sep):
                            shutil.rmtree(dest)
                            return self._json(200, {"ok": True, "id": mid or dest.name, "path": str(dest)})
                    except OSError as e:
                        return self._json(500, {"ok": False, "error": str(e), "id": mid})
                if not mid:
                    return self._json(400, {"error": "missing id", "ok": False})
                rc = cmd_uninstall(argparse.Namespace(model_id=mid))
                return self._json(
                    200 if rc == 0 else 404,
                    {
                        "ok": rc == 0,
                        "id": mid,
                        "error": None if rc == 0 else f"Not installed: {mid}",
                    },
                )
            if path == "/api/purge-impostors":
                rc = cmd_purge_impostors(argparse.Namespace())
                return self._json(200, {"ok": True, "purged": True, "rc": rc, "installed": _list_installed()})
            if path == "/api/workspace":
                root = (body.get("root") or body.get("path") or "").strip()
                if not root:
                    return self._json(400, {"ok": False, "error": "missing root"})
                if _agent_ws is None:
                    return self._json(500, {"ok": False, "error": "agent_workspace missing"})
                try:
                    info = _agent_ws.set_workspace(root)
                    _WORKSPACE["root"] = info["root"]
                    return self._json(200, info)
                except Exception as e:
                    return self._json(400, {"ok": False, "error": f"{type(e).__name__}: {e}"})
            if path in ("/api/workspace/pick", "/api/workspace/browse"):
                if _agent_ws is None:
                    return self._json(500, {"ok": False, "error": "agent_workspace missing"})
                try:
                    info = _agent_ws.pick_folder()
                    if info.get("ok") and info.get("root"):
                        _WORKSPACE["root"] = info["root"]
                    return self._json(200 if info.get("ok") or info.get("cancelled") else 400, info)
                except Exception as e:
                    return self._json(400, {"ok": False, "error": f"{type(e).__name__}: {e}"})
            if path == "/api/agent":
                if _agent_ws is None:
                    return self._json(500, {"ok": False, "error": "agent_workspace missing"})
                root_s = body.get("workspace") or body.get("root") or _WORKSPACE.get("root")
                if not root_s:
                    return self._json(
                        400,
                        {"ok": False, "error": "set a workspace folder first (POST /api/workspace)"},
                    )
                prompt = (body.get("prompt") or body.get("message") or "").strip()
                if not prompt:
                    return self._json(400, {"ok": False, "error": "empty prompt"})
                requested = body.get("model")
                ollama_tag = None
                snap = None
                if _is_ollama_model_id(requested):
                    ollama_tag = _ollama_tag(str(requested))
                    if not _ollama_reachable():
                        return self._json(
                            503,
                            {
                                "ok": False,
                                "error": (
                                    f"Ollama is not reachable at {OLLAMA_HOST}. "
                                    "Start it with `ollama serve`, then retry."
                                ),
                            },
                        )
                else:
                    snap = _resolve_model_dir(requested, model)
                    if snap is None or not snap.is_dir():
                        return self._json(
                            404,
                            {
                                "ok": False,
                                "error": (
                                    "Model not installed. Install a Mac 16GB Hugging Face model "
                                    "from Library, or select an Ollama model (ollama/…)."
                                ),
                            },
                        )
                try:
                    info = _agent_ws.set_workspace(str(root_s))
                    _WORKSPACE["root"] = info["root"]
                except Exception as e:
                    return self._json(400, {"ok": False, "error": f"{type(e).__name__}: {e}"})
                max_steps = int(body.get("max_steps") or 8)
                max_tokens = int(body.get("max_tokens") or 384)
                temperature = float(body.get("temperature") if body.get("temperature") is not None else 0.2)
                want_async = bool(body.get("async", True))

                def _run_agent():
                    return _agent_run(
                        snap=snap,
                        workspace=Path(_WORKSPACE["root"]),
                        prompt=prompt,
                        max_steps=max_steps,
                        max_tokens=max_tokens,
                        temperature=temperature,
                        ollama_model=ollama_tag,
                    )

                if not want_async:
                    result = _run_agent()
                    code = 200 if result.get("ok") else 400
                    return self._json(code, result)

                job_id = str(uuid.uuid4())
                _job_set(
                    job_id,
                    status="running",
                    pct=5,
                    message="Starting…",
                    kind="agent",
                    steps=[],
                    phase="start",
                    prompt=prompt[:500],
                )

                def _worker() -> None:
                    try:
                        def on_progress(message: str = "", **extra):
                            steps = extra.get("steps") or []
                            phase = extra.get("phase") or "running"
                            step_n = int(extra.get("step") or 0)
                            pct = min(95, 10 + step_n * 12)
                            if phase == "done":
                                pct = 100
                            _job_set(
                                job_id,
                                status="running" if phase != "done" else "running",
                                pct=pct,
                                message=message or phase,
                                kind="agent",
                                steps=steps,
                                phase=phase,
                                tool=extra.get("tool"),
                                step=step_n,
                            )

                        result = _agent_run(
                            snap=snap,
                            workspace=Path(_WORKSPACE["root"]),
                            prompt=prompt,
                            max_steps=max_steps,
                            max_tokens=max_tokens,
                            temperature=temperature,
                            ollama_model=ollama_tag,
                            on_progress=on_progress,
                        )
                        _job_set(
                            job_id,
                            status="done" if result.get("ok") else "error",
                            pct=100,
                            message="Done" if result.get("ok") else (result.get("error") or "failed"),
                            kind="agent",
                            steps=result.get("steps") or [],
                            summary=result.get("summary"),
                            result=result,
                            phase="done",
                            error=None if result.get("ok") else (result.get("error") or "failed"),
                        )
                    except Exception as e:
                        _job_set(
                            job_id,
                            status="error",
                            pct=0,
                            message=f"{type(e).__name__}: {e}",
                            kind="agent",
                            error=f"{type(e).__name__}: {e}",
                            phase="error",
                        )

                threading.Thread(target=_worker, daemon=True).start()
                return self._json(
                    200,
                    {"ok": True, "async": True, "job_id": job_id, "status": "running"},
                )
            if path in ("/v1/chat/completions", "/api/chat"):
                requested = body.get("model")
                messages = body.get("messages") or []
                if not any((m.get("content") or "").strip() for m in messages if m.get("role") == "user"):
                    return self._json(400, {"error": "empty prompt"})
                max_tokens = int(body.get("max_tokens") or 512)
                temperature = float(
                    body.get("temperature") if body.get("temperature") is not None else 0.7
                )
                want_stream = bool(body.get("stream"))

                if _is_ollama_model_id(requested):
                    if want_stream:
                        return self._json(
                            400,
                            {"error": "streaming not supported for Ollama bridge yet — set stream=false"},
                        )
                    if not _ollama_reachable():
                        return self._json(
                            503,
                            {
                                "error": (
                                    f"Ollama is not reachable at {OLLAMA_HOST}. "
                                    "Start it with `ollama serve` to use preinstalled models."
                                ),
                                "requested": requested,
                            },
                        )
                    tag = _ollama_tag(str(requested))
                    text, stats = _ollama_chat(messages, max_tokens, temperature, model_tag=tag)
                    if stats.get("error") and str(text).startswith("(ollama error:"):
                        return self._json(502, {"error": stats["error"], "requested": requested})
                    mid_ = f"ollama/{tag}"
                    return self._json(
                        200,
                        {
                            "id": f"chatcmpl-ollama-{uuid.uuid4().hex[:10]}",
                            "object": "chat.completion",
                            "created": int(time.time()),
                            "model": mid_,
                            "choices": [
                                {
                                    "index": 0,
                                    "message": {"role": "assistant", "content": text},
                                    "finish_reason": "stop",
                                }
                            ],
                            "usage": {
                                "completion_tokens": stats.get("completion_tokens") or 0,
                                "prompt_tokens": 0,
                                "total_tokens": stats.get("completion_tokens") or 0,
                            },
                            "windhover": stats,
                        },
                    )

                snap = _resolve_model_dir(requested, model)
                if snap is None or not snap.is_dir():
                    return self._json(
                        404 if requested and requested not in ("kestrel", "default", "auto") else 503,
                        {
                            "error": (
                                f"Model {requested!r} is not installed. "
                                "Install a **Mac 16GB** Hugging Face model from Library, "
                                "download full weights, or pick an **Ollama** model "
                                "(shown when `ollama serve` is running)."
                                if requested and requested not in ("kestrel", "default", "auto", None)
                                else "No model loaded. Install a Hugging Face model from Library "
                                "(Mac 16GB filter), or start Ollama."
                            ),
                            "requested": requested,
                        },
                    )
                mode = _chat_mode(snap)
                if mode == "blocked":
                    mid = _snap_meta(snap).get("id") or snap.name
                    incomplete = not _has_real_weights(snap) and not _has_kpk(snap)
                    if incomplete:
                        return self._json(
                            400,
                            {
                                "error": (
                                    f"{mid} is incomplete — model weights never finished downloading. "
                                    "Uninstall it in Library, then Install again (Mac 16GB) to get real weights."
                                ),
                                "incomplete": True,
                                "id": mid,
                            },
                        )
                    return self._json(
                        400,
                        {
                            "error": (
                                f"{mid} can’t chat (missing weights or fake stub). "
                                "Uninstall it, then install a real Hugging Face Mac 16GB model from Library."
                            ),
                            "impostor": _is_impostor_pack(snap),
                            "id": mid,
                        },
                    )
                stats: dict = {}
                if mode == "preview":
                    text, stats = _preview_chat(messages, max_tokens, temperature, snap=snap)
                    backend = "preview"
                else:
                    # Phi/Gemma need a KPK; Qwen/Llama/Mistral can run raw HF via dense.c.
                    # Do not block the HTTP request for multi-minute converts — prepare async.
                    if not _ensure_engine_pack(snap, blocking=False):
                        if _transformers_available() and _has_real_weights(snap):
                            text, stats = _preview_chat(
                                messages, max_tokens, temperature, snap=snap
                            )
                            backend = "preview"
                            return self._json(
                                200,
                                {
                                    "id": "kestrel-chat",
                                    "object": "chat.completion",
                                    "model": body.get("model")
                                    or _snap_meta(snap).get("id")
                                    or snap.name,
                                    "backend": backend,
                                    "engine_active": False,
                                    "stats": stats,
                                    "usage": {
                                        "completion_tokens": stats.get("completion_tokens") or 0,
                                        "total_tokens": stats.get("completion_tokens") or 0,
                                    },
                                    "choices": [
                                        {
                                            "index": 0,
                                            "message": {"role": "assistant", "content": text},
                                            "finish_reason": "stop",
                                        }
                                    ],
                                },
                            )
                        if _windhover_supported(snap) and _has_real_weights(snap):
                            job_id = _start_prepare_job(snap)
                            return self._json(
                                202,
                                {
                                    "ok": False,
                                    "error": (
                                        "Preparing this model for windhover-engine "
                                        "(converting weights). This can take several minutes "
                                        "for Phi-4. Watch progress, then send again."
                                    ),
                                    "code": "engine_preparing",
                                    "job_id": job_id,
                                    "engine_active": False,
                                    "id": _snap_meta(snap).get("id") or snap.name,
                                },
                            )
                        return self._json(
                            503,
                            _engine_inactive_payload(
                                "Windhover engine could not prepare this model for chat "
                                "(KPK convert failed). "
                                "Re-install from Library or check the server log.",
                                detail=_LAST_CONVERT_ERROR,
                            ),
                        )
                    prompt = ""
                    for m in messages:
                        if m.get("role") == "user":
                            prompt = m.get("content") or ""
                    if not ENGINE_BIN.is_file():
                        return self._json(
                            503,
                            _engine_inactive_payload(
                                "Windhover engine is not active — binary missing. "
                                "Run `./windhover build`, then restart the app."
                            ),
                        )
                    if want_stream:
                        # OpenAI-style SSE: chunks as the engine emits bytes
                        mid_ = body.get("model") or _snap_meta(snap).get("id") or snap.name
                        self.send_response(200)
                        self.send_header("Content-Type", "text/event-stream")
                        self.send_header("Cache-Control", "no-cache")
                        self.send_header("X-Accel-Buffering", "no")
                        self.end_headers()

                        def _sse(obj):
                            try:
                                self.wfile.write(
                                    b"data: " + json.dumps(obj).encode() + b"\n\n")
                                self.wfile.flush()
                            except (BrokenPipeError, ConnectionResetError):
                                raise

                        def on_delta(piece: str):
                            _sse({
                                "id": "kestrel-chat",
                                "object": "chat.completion.chunk",
                                "model": mid_,
                                "choices": [{"index": 0,
                                             "delta": {"content": piece},
                                             "finish_reason": None}],
                            })

                        try:
                            _text, stats = _engine_chat(
                                snap, prompt, max_tokens, temperature,
                                messages=messages, on_delta=on_delta,
                            )
                            _sse({
                                "id": "kestrel-chat",
                                "object": "chat.completion.chunk",
                                "model": mid_,
                                "stats": stats,
                                "choices": [{"index": 0, "delta": {},
                                             "finish_reason": "stop"}],
                            })
                            self.wfile.write(b"data: [DONE]\n\n")
                            self.wfile.flush()
                        except EngineInactiveError as e:
                            _sse({
                                "id": "kestrel-chat",
                                "object": "chat.completion.chunk",
                                "model": mid_,
                                "error": str(e),
                                "code": "engine_inactive",
                                "engine_active": False,
                                "detail": e.detail,
                                "choices": [{"index": 0, "delta": {},
                                             "finish_reason": "error"}],
                            })
                            self.wfile.write(b"data: [DONE]\n\n")
                            try:
                                self.wfile.flush()
                            except (BrokenPipeError, ConnectionResetError):
                                pass
                        except (BrokenPipeError, ConnectionResetError):
                            pass
                        return None
                    try:
                        text, stats = _engine_chat(
                            snap, prompt, max_tokens, temperature, messages=messages
                        )
                        backend = "windhover-engine"
                    except EngineInactiveError as e:
                        return self._json(
                            503,
                            _engine_inactive_payload(str(e), detail=e.detail),
                        )
                    # If KPK/engine path produced no usable answer but HF weights exist,
                    # fall back to transformers only when available (not in packaged apps).
                    bad_eng = (
                        not (text or "").strip()
                        or str(text).startswith("The model returned an empty")
                        or str(text).startswith("windhover-engine ran this pack")
                        or _looks_like_engine_garbage(str(text))
                    )
                    if bad_eng and _has_real_weights(snap) and _transformers_available():
                        sys.stderr.write(
                            "[windhover] engine reply unusable — falling back to transformers "
                            "(engine inactive for this turn)\n"
                        )
                        eng_err = (
                            "Windhover engine is not active for this reply — "
                            "output was unusable, using transformers fallback."
                        )
                        text, stats = _preview_chat(
                            messages, max_tokens, temperature, snap=snap
                        )
                        backend = "preview"
                        stats = {
                            **stats,
                            "fallback_from": "windhover-engine",
                            "engine_active": False,
                            "engine_error": eng_err,
                        }
                        _LAST_STATS.update(stats)
                    elif bad_eng:
                        return self._json(
                            503,
                            _engine_inactive_payload(
                                "Windhover engine is not active — the model produced no usable "
                                "reply. Re-install from Library or re-convert the pack."
                            ),
                        )
                return self._json(
                    200,
                    {
                        "id": "kestrel-chat",
                        "object": "chat.completion",
                        "model": body.get("model") or _snap_meta(snap).get("id") or snap.name,
                        "backend": backend,
                        "engine_active": bool(stats.get("engine_active", backend == "windhover-engine")),
                        "stats": stats,
                        "usage": {
                            "completion_tokens": stats.get("completion_tokens") or 0,
                            "total_tokens": stats.get("completion_tokens") or 0,
                        },
                        "choices": [
                            {
                                "index": 0,
                                "message": {"role": "assistant", "content": text},
                                "finish_reason": "stop",
                            }
                        ],
                    },
                )
            self.send_error(404)

    print(f"Windhover listening on http://{host}:{port}  (Library API + static app)")
    if model:
        print(f"  model: {model}")
    ThreadingHTTPServer((host, port), H).serve_forever()
    return 0


def cmd_app(ns: argparse.Namespace) -> int:
    # Prefer built UI; fall back to public/
    dist = ROOT / "app" / "dist"
    if not dist.is_dir():
        pkg = ROOT / "app" / "package.json"
        if pkg.is_file() and not os.environ.get("WINDHOVER_APP_NO_AUTOPULL"):
            print("building app...")
            subprocess.call(["npm", "run", "build"], cwd=str(ROOT / "app"))
    # Packaged desktop sidecars set WINDHOVER_APP_NO_AUTOPULL=1. Defer impostor
    # cleanup so /health comes up immediately (avoids a long frozen first launch).
    if os.environ.get("WINDHOVER_APP_NO_AUTOPULL"):
        threading.Thread(
            target=lambda: cmd_purge_impostors(argparse.Namespace()),
            daemon=True,
            name="purge-impostors",
        ).start()
    else:
        cmd_purge_impostors(argparse.Namespace())
    model = Path(ns.model) if ns.model else None
    if model is None:
        installed = [
            m
            for m in _list_installed()
            if m.get("chat_ok")
            and not str(m.get("id") or "").startswith("ollama/")
            and m.get("path")
        ]
        if installed:
            model = Path(installed[0]["path"])
    return _serve_library_api(ns.host, ns.port, model)


def cmd_bench(ns: argparse.Namespace) -> int:
    """Run fair stock vs kestrel bench, refresh chart, verify gates."""
    if getattr(ns, "real", False):
        script = ROOT / "tools" / "real_model_bench.py"
        if not script.is_file():
            print(f"missing {script}", file=sys.stderr)
            return 1
        return subprocess.call([sys.executable, str(script)], cwd=str(ROOT))
    if getattr(ns, "dense", False):
        script = ROOT / "tools" / "dense_qwen_bench.py"
        if not script.is_file():
            print(f"missing {script}", file=sys.stderr)
            return 1
        return subprocess.call([sys.executable, str(script)], cwd=str(ROOT))
    if getattr(ns, "windhover", False):
        script = ROOT / "tools" / "windhover_bench.py"
        if not script.is_file():
            print(f"missing {script}", file=sys.stderr)
            return 1
        return subprocess.call([sys.executable, str(script)], cwd=str(ROOT))
    if getattr(ns, "qwen", False):
        script = ROOT / "tools" / "qwen7b_bench.py"
        if not script.is_file():
            print(f"missing {script}", file=sys.stderr)
            return 1
        return subprocess.call([sys.executable, str(script)], cwd=str(ROOT))
    if getattr(ns, "laptop", False):
        # Max-feasible stress on this machine (synthetic MoE; not GLM-5.2/Kimi).
        for name in ("laptop_limit_bench.py", "laptop_soak_bench.py"):
            script = ROOT / "tools" / name
            if not script.is_file():
                print(f"missing {script}", file=sys.stderr)
                return 1
            rc = subprocess.call([sys.executable, str(script)], cwd=str(ROOT))
            if rc != 0:
                return rc
        return 0
    script = ROOT / "tools" / "full_bench.py"
    verify = ROOT / "tools" / "verify_bench.py"
    chart = ROOT / "tools" / "render_bench_chart.py"
    if not script.is_file():
        print(f"missing {script}", file=sys.stderr)
        return 1
    env = os.environ.copy()
    if getattr(ns, "quick", False):
        env["BENCH_BATCHES"] = "4"
        env["BENCH_BATCH_SIZE"] = "20"
        env["BENCH_WARMUP"] = "1"
    rc = subprocess.call([sys.executable, str(script)], cwd=str(ROOT), env=env)
    if rc != 0:
        return rc
    if chart.is_file():
        subprocess.call([sys.executable, str(chart)], cwd=str(ROOT))
    if verify.is_file():
        venv = env.copy()
        if getattr(ns, "smoke", False):
            venv["VERIFY_BENCH_RERUN"] = "1"
        rc = subprocess.call([sys.executable, str(verify)], cwd=str(ROOT), env=venv)
        if rc != 0:
            return rc
    status = ROOT / "docs" / "bench_loop_status.json"
    bench = ROOT / "docs" / "full_bench.json"
    if bench.is_file():
        data = json.loads(bench.read_text(encoding="utf-8"))
        cmp_ = data.get("comparison") or {}
        thr = cmp_.get("throughput_pos_per_s") or {}
        wall = cmp_.get("batch_wall_s") or {}
        payload = {
            "goal_10pct": True,
            "goal_met": bool(cmp_.get("goal_10pct_throughput")),
            "product_engine": "engine/windhover-engine",
            "oracle": "32/32",
            "benchmark": "docs/full_bench.json",
            "verified_by": "tools/verify_bench.py",
            "protocol": {
                "batches": data.get("meta", {}).get("batches"),
                "batch_size": data.get("meta", {}).get("batch_size"),
                "warmup_batches": data.get("meta", {}).get("warmup_batches"),
                "schedule": "interleaved",
                "stock_upstream_sha": data.get("meta", {}).get("stock_upstream_sha"),
                "sha_match": data.get("meta", {}).get("sha_match"),
            },
            "d_throughput_pct": thr.get("delta_pct"),
            "d_batch_wall_pct": wall.get("delta_pct"),
            "pos_per_s": {
                "stock_mean": thr.get("stock_mean"),
                "kestrel_mean": thr.get("kestrel_mean"),
            },
            "batch_wall_s": {
                "stock_mean": wall.get("stock_mean"),
                "kestrel_mean": wall.get("kestrel_mean"),
            },
            "timestamp_utc": data.get("meta", {}).get("timestamp_utc"),
            "notes": "Fair bench on glm_tiny: without Windhover (baseline) vs with Windhover on the same laptop",
        }
        status.write_text(json.dumps(payload, indent=2) + "\n")
        print(f"updated {status}")
    return 0


def cmd_convert(ns: argparse.Namespace) -> int:
    snap = Path(ns.model)
    if not snap.is_dir():
        snap = MODELS_DIR / ns.model.replace("/", "__")
    if not snap.is_dir():
        print(f"model not found: {ns.model}", file=sys.stderr)
        return 1
    if not _windhover_supported(snap):
        cfg_mt = ""
        try:
            cfg_mt = str(json.loads((snap / "config.json").read_text(encoding="utf-8")).get("model_type") or "")
        except Exception:
            pass
        hint = ""
        if cfg_mt.lower() in ("qwen3_5", "qwen3.5") or "qwen3.5" in snap.name.lower():
            hint = (
                " Official Qwen3.5-9B is hybrid qwen3_5 (not dense). "
                "Install Qwen/Qwen3-8B for windhover-engine int4/Q4 instead."
            )
        print(
            f"{snap.name}: unsupported for Windhover (dense qwen2/qwen3/llama/"
            f"mistral/gemma2/gemma3/phi3 only).{hint}",
            file=sys.stderr,
        )
        return 1
    if ns.force:
        shutil.rmtree(snap / "kpk", ignore_errors=True)
    tool = ROOT / "tools" / "kestrel_pack.py"
    py = _ml_python()
    cmd = [py, str(tool), "--snap", str(snap),
           "--attn-bits", str(ns.attn_bits)]
    if ns.no_calib:
        cmd += ["--no-calib", "--no-awq"]
    rc = subprocess.call(cmd)
    if rc != 0 and not ns.no_calib:
        # calibration needs torch; fall back to plain quant pack
        print("convert with calib failed - retrying without AWQ/calib...", file=sys.stderr)
        rc = subprocess.call(
            [py, str(tool), "--snap", str(snap), "--attn-bits", str(ns.attn_bits),
             "--no-calib", "--no-awq"]
        )
    if rc == 0 and _has_kpk(snap):
        meta = _snap_meta(snap)
        _write_kestrel_meta(
            snap,
            str(meta.get("id") or snap.name.replace("__", "/")),
            {},
            runner=False,
            chat="engine",
            weights=True,
            tier=meta.get("tier"),
            source=meta.get("source"),
            size_bytes=_dir_bytes(snap),
            engine="windhover-engine",
        )
        print(f"KPK ready: {snap / 'kpk'}")
    return rc


def main() -> int:
    _ensure_nofile()
    ap = argparse.ArgumentParser(prog="windhover", description="Windhover local LLM runtime")
    sp = ap.add_subparsers(dest="cmd", required=True)

    sp.add_parser("build", help="build engine/windhover-engine")
    sp.add_parser("oracle", help="TF 32/32 self-test")

    p = sp.add_parser("bench", help="fair without-vs-with Windhover bench + verify")
    p.add_argument(
        "--quick",
        action="store_true",
        help="shorter protocol (4×20) for smoke; default is full 12×40",
    )
    p.add_argument(
        "--smoke",
        action="store_true",
        help="after verify, also re-run one live 40-proc batch each side",
    )
    p.add_argument(
        "--real",
        action="store_true",
        help="frontier MoE bench (needs WINDHOVER_SNAP / KESTREL_SNAP); refuses glm_tiny",
    )
    p.add_argument(
        "--dense",
        action="store_true",
        help="Qwen2.5-Coder-1.5B without/with windhover-engine dense path (needs pull + build)",
    )
    p.add_argument(
        "--windhover",
        action="store_true",
        help="Windhover KPK bench (1.5B/7B under ~/.windhover/models); writes docs/windhover_bench.json",
    )
    p.add_argument(
        "--qwen",
        action="store_true",
        help="legacy Qwen2.5-7B preview-path bench (see --dense for engine)",
    )
    p.add_argument(
        "--laptop",
        action="store_true",
        help="laptop-limit + concurrent soak on glm_stress (synthetic; pushes 16GB class)",
    )

    p = sp.add_parser("doctor", help="diagnostics")
    p.add_argument("--model", default=None)

    p = sp.add_parser("plan", help="resource plan")
    p.add_argument("--model", default=None)
    p.add_argument("--ram", type=float, default=None)

    p = sp.add_parser("chat", help="one-shot / interactive chat")
    p.add_argument("--model", required=True)
    p.add_argument("--prompt", default=None)
    p.add_argument("--ngen", type=int, default=64)
    p.add_argument("--temp", type=float, default=0.0)
    p.add_argument("--cap", type=int, default=64)
    p.add_argument("--ram", type=float, default=None)

    p = sp.add_parser("serve", help="HTTP API")
    p.add_argument("--model", default=None)
    p.add_argument("--host", default="127.0.0.1")
    p.add_argument("--port", type=int, default=8000)
    p.add_argument("--ram", type=float, default=None)

    p = sp.add_parser("pull", help="install catalog model onto windhover-engine")
    p.add_argument("model_id")
    p.add_argument(
        "--weights",
        action="store_true",
        help="download full HF weights (required for frontier MoEs; auto for Mac 16GB / hf_small)",
    )

    p = sp.add_parser("uninstall", help="remove an installed model")
    p.add_argument("model_id")

    sp.add_parser("purge-impostors", help="remove fake MoE stub installs")

    p = sp.add_parser("convert", help="build a Windhover KPK pack from an installed dense model")
    p.add_argument("model", help="catalog id or model directory")
    p.add_argument("--no-calib", action="store_true", help="skip torch calibration (no AWQ/sparsity)")
    p.add_argument("--attn-bits", type=int, default=8, choices=(4, 8))
    p.add_argument("--force", action="store_true", help="re-convert even if a KPK pack exists")

    p = sp.add_parser("app", help="Library + Chat UI")
    p.add_argument("--model", default=None)
    p.add_argument("--host", default="127.0.0.1")
    p.add_argument("--port", type=int, default=8000)

    ns = ap.parse_args()
    handlers = {
        "build": cmd_build,
        "oracle": cmd_oracle,
        "bench": cmd_bench,
        "doctor": cmd_doctor,
        "plan": cmd_plan,
        "chat": cmd_chat,
        "serve": cmd_serve,
        "pull": cmd_pull,
        "uninstall": cmd_uninstall,
        "purge-impostors": cmd_purge_impostors,
        "convert": cmd_convert,
        "app": cmd_app,
    }
    return handlers[ns.cmd](ns)


if __name__ == "__main__":
    raise SystemExit(main())
