def _rss_mb() -> float:
    try:
        import resource

        rss = float(resource.getrusage(resource.RUSAGE_SELF).ru_maxrss)
        if sys.platform == "darwin":
            return rss / (1024.0 * 1024.0)
        return rss / 1024.0
    except Exception:
        return 0.0


def _clean_chat_text(text: str, *, soft: bool = False) -> str:
    """Strip chat-template / control tokens and tidy layout for UI display.

    soft=True: only remove complete control tokens (safe for streaming deltas).
    """
    import re

    if not text:
        return text
    s = text
    # ChatML / Qwen / Llama / Gemma / Phi style control tokens
    s = re.sub(r"<\|[^|>]+?\|>", "", s)
    s = re.sub(r"</?s>", "", s)
    s = re.sub(r"<end_of_turn>", "", s)
    s = re.sub(r"<start_of_turn>\w*", "", s)
    s = re.sub(r"\[/?INST\]", "", s)
    s = re.sub(r"<<SYS>>|<</SYS>>", "", s)
    if soft:
        return s
    # Collapse messy whitespace left behind by stripped tokens
    s = re.sub(r"[ \t]+\n", "\n", s)
    s = re.sub(r"\n{3,}", "\n\n", s)
    return s.strip()


