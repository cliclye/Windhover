# Windows consoles default to a legacy code page (cp1252/charmap). Progress
# messages and huggingface_hub/tqdm use Unicode (e.g. U+2192), which raises
# UnicodeEncodeError and aborts Library downloads. Force UTF-8 early and wrap
# stdio so a failed reconfigure can never crash a pull.
os.environ.setdefault("PYTHONUTF8", "1")
os.environ.setdefault("PYTHONIOENCODING", "utf-8")
