def _is_impostor_pack(snap: Path) -> bool:
    """True if a tiny/empty stub was labeled as a real HF model."""
    meta = _snap_meta(snap)
    mid = str(meta.get("id") or snap.name).replace("__", "/")
    if mid.startswith(("windhover/chat-preview", "kestrel/chat-preview")) or mid.startswith(("windhover/glm-tiny", "kestrel/glm-tiny")):
        return False
    if meta.get("impostor") is True:
        return True
    if meta.get("runner") is True and not mid.startswith(("windhover/", "kestrel/")):
        return True
    # Empty marker installs (the instant “Install” bug) claiming to be Qwen/etc.
    if meta.get("chat") == "preview" and not _has_real_weights(snap):
        return True
    if meta.get("weights") and not _has_real_weights(snap):
        return True
    if meta.get("source") == "hf_small" and not _has_real_weights(snap):
        return True
    if _is_tiny_stub(snap) and (
        "/" in mid
        or any(
            mid.startswith(p) or snap.name.startswith(p.replace("/", "__"))
            for p in (
                "moonshotai",
                "Qwen",
                "deepseek",
                "zai-org",
                "mistralai",
                "meta-llama",
                "HuggingFaceTB",
                "TinyLlama",
                "microsoft",
                "google",
            )
        )
    ):
        return True
    return False


def _dense_engine_supported(snap: Path) -> bool:
    """True when windhover-engine dense/Windhover path can load this SNAP
    (Qwen2/3, Llama, Mistral, Gemma2/3, Phi-3)."""
    cfg_path = snap / "config.json"
    if not cfg_path.is_file():
        return False
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    # MoE packs use engine.c (same int4+IDOT family), not dense/windhover
    if cfg.get("n_routed_experts") or cfg.get("num_experts") or cfg.get("num_local_experts"):
        return False
    arches = " ".join(str(a) for a in (cfg.get("architectures") or []))
    if any(
        x in arches
        for x in (
            "MixtralForCausalLM",
            "Qwen2MoeForCausalLM",
            "Qwen3MoeForCausalLM",
        )
    ):
        return False
    mt = str(cfg.get("model_type") or "").lower()
    if mt in ("qwen2", "qwen3", "llama", "mistral", "gemma2", "gemma3", "phi3"):
        return True
    return any(
        x in arches
        for x in (
            "Qwen2ForCausalLM",
            "Qwen3ForCausalLM",
            "LlamaForCausalLM",
            "MistralForCausalLM",
            "Gemma2ForCausalLM",
            "Gemma3ForCausalLM",
            "Phi3ForCausalLM",
        )
    )


def _engine_faithful(snap: Path) -> bool:
    """False when the pack needs RoPE/features windhover-engine does not implement yet.

    Phi-4 Mini partial RoPE + longrope attention scale are supported in windhover.c.
    Yarn/dynamic/linear scaling still fall back to transformers when HF weights exist.
    """
    candidates = [snap / "config.json"]
    if snap.name == "kpk":
        candidates.insert(0, snap.parent / "config.json")
    cfg = None
    for cfg_path in candidates:
        if not cfg_path.is_file():
            continue
        try:
            cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
            break
        except Exception:
            continue
    if not cfg:
        return True
    rs = cfg.get("rope_scaling") or cfg.get("rope_parameters") or {}
    if isinstance(rs, dict):
        rtype = str(rs.get("type") or rs.get("rope_type") or "").lower()
        if rtype in ("yarn", "dynamic", "linear"):
            return False
    return True


class EngineInactiveError(RuntimeError):
    """windhover-engine binary missing, crash, or refused to run."""

    def __init__(self, message: str, *, detail: str | None = None):
        super().__init__(message)
        self.detail = (detail or "").strip() or None


def _looks_like_engine_garbage(text: str) -> bool:
    """Heuristic for degenerate engine decode (nulls, hex soup, phrase loops)."""
    import re

    t = (text or "").strip()
    if not t:
        return True
    if "\x00" in t or t.count("\ufffd") >= 3:
        return True
    if re.search(r"[|]{8,}", t) or re.search(r"[.]{12,}", t):
        return True
    if re.search(r"[\x00-\x08\x0b\x0c\x0e-\x1f]", t):
        return True
    if re.search(r"(\b\w{1,4}\b(?:\s+\b\w{1,4}\b){25,})", t):
        return True
    if re.search(r"(.{12,80}?)(?:\s*\1){2,}", t, flags=re.DOTALL):
        return True
    weird = sum(1 for c in t if ord(c) < 32 and c not in "\n\t\r")
    if len(t) > 40 and weird / len(t) > 0.05:
        return True
    return False


def _engine_inactive_payload(message: str, *, detail: str | None = None) -> dict:
    """JSON body when Chat/Agent cannot use windhover-engine."""
    out = {
        "error": message,
        "code": "engine_inactive",
        "engine_active": False,
        "engine": str(ENGINE_BIN),
        "engine_present": ENGINE_BIN.is_file(),
    }
    if detail:
        out["detail"] = detail[:2000]
    return out


def _has_kpk(snap: Path) -> bool:
    """True when a Windhover KPK pack exists (snap/kpk or snap itself)."""
    for d in (snap / "kpk", snap):
        kj = d / "kestrel.json"
        if kj.is_file():
            try:
                if "windhover" in json.loads(kj.read_text(encoding="utf-8")):
                    return True
            except Exception:
                pass
    return False


def _windhover_supported(snap: Path) -> bool:
    """True when tools/kestrel_pack.py can convert this pack for the
    Windhover runtime (dense qwen2/qwen3/llama/mistral/gemma2/gemma3/phi3)."""
    cfg_path = snap / "config.json"
    if not cfg_path.is_file():
        return False
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    if cfg.get("n_routed_experts") or cfg.get("num_experts") or cfg.get("num_local_experts"):
        return False
    mt = str(cfg.get("model_type") or "").lower()
    return mt in ("qwen2", "qwen3", "llama", "mistral", "gemma2", "gemma3", "phi3")


def _snap_key(snap: Path) -> str:
    try:
        return str(snap.resolve())
    except Exception:
        return str(snap)


def _kpk_convert(snap: Path, job_id: str | None = None) -> bool:
    """Run the one-time Windhover convert (quant + calibrate + AWQ). ~1-2 min/GB.

    Packaged apps (frozen / no torch) convert in-process with --no-calib/--no-awq
    using numpy + safetensors only.
    """
    global _LAST_CONVERT_ERROR
    _LAST_CONVERT_ERROR = None
    tool = ROOT / "tools" / "kestrel_pack.py"
    if os.environ.get("WINDHOVER_NO_KPK") or os.environ.get("KESTREL_NO_KPK"):
        _LAST_CONVERT_ERROR = "KPK convert disabled (WINDHOVER_NO_KPK)."
        return False
    if _has_kpk(snap):
        return True
    if job_id:
        _job_set(
            job_id,
            status="running",
            pct=50,
            message="Converting weights for windhover-engine…",
            phase="convert",
        )
    print("running Windhover convert (one-time quantize)...")

    frozen = bool(getattr(sys, "frozen", False))
    # Always prefer in-process on Windows packaged builds and whenever torch is absent.
    use_inprocess = (
        frozen
        or sys.platform == "win32"
        or not tool.is_file()
        or not _transformers_available()
    )

    def _progress(done: int, total: int, message: str) -> None:
        if not job_id or total <= 0:
            return
        # Map convert into 50–99% so download jobs can use 0–50 earlier.
        pct = 50 + int(49 * max(0, min(done, total)) / total)
        _job_set(job_id, status="running", pct=pct, message=message, phase="convert")

    if use_inprocess:
        try:
            tools_dir = str(ROOT / "tools")
            if tools_dir not in sys.path:
                sys.path.insert(0, tools_dir)
            import kestrel_pack as kp  # type: ignore

            outdir_path = snap / "kpk"
            # Clear a half-written pack from a previous failed convert.
            if outdir_path.is_dir() and not _has_kpk(snap):
                shutil.rmtree(outdir_path, ignore_errors=True)
            outdir = str(outdir_path)
            # No torch in the sidecar: skip calibration / AWQ (still a valid KPK).
            kp.convert(
                str(snap),
                outdir,
                awq=False,
                calib=False,
                on_progress=_progress,
            )
            ok = _has_kpk(snap)
            if not ok:
                _LAST_CONVERT_ERROR = (
                    "KPK convert finished but kestrel.json is missing a windhover block."
                )
            return ok
        except Exception as e:
            _LAST_CONVERT_ERROR = f"{type(e).__name__}: {e}"
            sys.stderr.write(f"[windhover] in-process KPK convert failed: {_LAST_CONVERT_ERROR}\n")
            # Don't leave a broken kpk/ that blocks retries.
            try:
                if (snap / "kpk").is_dir() and not _has_kpk(snap):
                    shutil.rmtree(snap / "kpk", ignore_errors=True)
            except Exception:
                pass
            return False

    py = _ml_python()
    rc = subprocess.call([py, str(tool), "--snap", str(snap)])
    if rc != 0:
        # calibration needs torch; fall back to plain quant pack
        rc = subprocess.call(
            [py, str(tool), "--snap", str(snap), "--no-calib", "--no-awq"]
        )
    ok = rc == 0 and _has_kpk(snap)
    if not ok:
        _LAST_CONVERT_ERROR = f"kestrel_pack exited with code {rc}"
    return ok


def _start_prepare_job(snap: Path) -> str:
    """Start (or reuse) a background KPK convert job for this snap. Returns job_id."""
    key = _snap_key(snap)
    with _PREPARE_LOCK:
        existing = _PREPARE_BY_SNAP.get(key)
        if existing:
            job = _job_get(existing) or {}
            if job.get("status") == "running":
                return existing
        job_id = str(uuid.uuid4())
        _PREPARE_BY_SNAP[key] = job_id
        mid = _snap_meta(snap).get("id") or snap.name
        _job_set(
            job_id,
            status="running",
            pct=50,
            message=f"Preparing {mid} for windhover-engine…",
            phase="convert",
            model_id=mid,
            snap=str(snap),
        )

    def _worker() -> None:
        ok = _kpk_convert(snap, job_id)
        if ok:
            _job_set(
                job_id,
                status="done",
                pct=100,
                message="Engine pack ready — try Chat again.",
                phase="convert",
            )
        else:
            _job_set(
                job_id,
                status="error",
                pct=0,
                error=_LAST_CONVERT_ERROR or "KPK convert failed",
                message="Engine pack convert failed",
                phase="convert",
            )
        with _PREPARE_LOCK:
            if _PREPARE_BY_SNAP.get(key) == job_id:
                _PREPARE_BY_SNAP.pop(key, None)

    threading.Thread(target=_worker, daemon=True, name=f"wh-prepare-{snap.name}").start()
    return job_id


def _ensure_engine_pack(snap: Path, *, blocking: bool = True) -> bool:
    """Make SNAP runnable by windhover-engine without transformers.

    Qwen/Llama/Mistral: dense load-time quant on raw HF weights.
    Phi/Gemma/etc.: build a KPK pack (numpy convert) when supported.

    blocking=False starts a background prepare job and returns False until ready
    (used by Chat so the HTTP request does not hang for minutes).
    """
    if _has_kpk(snap) or _dense_loadtime_ok(snap):
        return True
    if not (_windhover_supported(snap) and _has_real_weights(snap)):
        return False
    if blocking:
        return _kpk_convert(snap)
    # Non-blocking: kick off convert and let the client poll /api/jobs.
    _start_prepare_job(snap)
    return _has_kpk(snap)


def _chat_mode(snap: Path) -> str:
    """Return preview | engine | engine-oracle | blocked."""
    meta = _snap_meta(snap)
    mid = str(meta.get("id") or snap.name).replace("__", "/")
    chat = meta.get("chat")
    if mid.endswith("chat-preview") or meta.get("source") == "preview":
        return "preview"
    if _is_demo_pack(snap) or _is_impostor_pack(snap):
        return "blocked"
    if chat == "engine-oracle" or mid.startswith(("windhover/glm-tiny", "kestrel/glm-tiny")):
        return "engine-oracle"
    if meta.get("runner") and mid.startswith(("windhover/", "kestrel/")):
        return "engine-oracle"

    has_w = _has_real_weights(snap)
    has_k = _has_kpk(snap) or (
        any((snap / "kpk").glob("kpk-*.safetensors")) if (snap / "kpk").is_dir() else False
    )

    # Incomplete HF checkout (tokenizer only, download interrupted) — not chat-capable.
    if not has_w and not has_k:
        return "blocked"

    # Prefer windhover-engine whenever the pack is (or can be) engine-runnable.
    # Never force transformers preview on packaged apps (no torch in the sidecar).
    if has_k:
        if _engine_faithful(snap) or not has_w:
            return "engine"
        if _transformers_available():
            return "preview"
        return "engine"

    if has_w and _engine_faithful(snap):
        if (
            chat in ("engine", "engine-oracle")
            or _dense_loadtime_ok(snap)
            or _windhover_supported(snap)
        ):
            return "engine"

    if has_w and _transformers_available():
        return "preview"

    if _is_tiny_stub(snap) and not mid.startswith(("windhover/", "kestrel/")):
        return "blocked"
    return "blocked"


def _format_engine_prompt(snap: Path, messages: list | None, flat_prompt: str) -> str:
    """Apply HF chat template when available so dense/engine packs get instruct formatting."""
    if messages:
        try:
            from transformers import AutoTokenizer

            tok = AutoTokenizer.from_pretrained(str(snap), trust_remote_code=True)
            chat = []
            for m in messages:
                role = m.get("role") or "user"
                content = (m.get("content") or "").strip()
                if content and role in ("user", "assistant", "system"):
                    chat.append({"role": role, "content": content})
            if chat and hasattr(tok, "apply_chat_template") and tok.chat_template:
                return tok.apply_chat_template(chat, tokenize=False, add_generation_prompt=True)
        except Exception as e:
            sys.stderr.write(f"[windhover] chat template fallback: {e}\n")
    if messages:
        parts = []
        for m in messages:
            role = m.get("role") or "user"
            content = (m.get("content") or "").strip()
            if content:
                parts.append(f"{role}: {content}")
        if parts:
            return "\n".join(parts) + "\nassistant:"
    return flat_prompt


def _preview_load_src(snap: Path | None, meta: dict, repo: str) -> str:
    """Prefer a real local HF checkout when weights were downloaded."""
    if snap and meta.get("weights"):
        if (snap / "config.json").is_file() and (
            any(snap.glob("*.safetensors")) or any(snap.glob("model*.bin")) or (snap / "pytorch_model.bin").is_file()
        ):
            return str(snap)
    return repo


def _preview_chat(
    messages: list,
    max_tokens: int,
    temperature: float,
    *,
    snap: Path | None = None,
) -> tuple[str, dict]:
    """On-device transformers chat for Mac-16GB small HF models."""
    import time

    _ensure_ml_imports()
    t0 = time.perf_counter()
    meta = _snap_meta(snap) if snap else {}
    repo = meta.get("preview_repo") or meta.get("hf_repo") or PREVIEW_REPO
    selected = meta.get("id") or "windhover/chat-preview"
    display = meta.get("name") or selected
    load_src = _preview_load_src(snap, meta, repo)
    try:
        import torch
        from transformers import AutoModelForCausalLM, AutoTokenizer

        if load_src not in _PREVIEW_PIPES:
            sys.stderr.write(f"[windhover] loading small model: {load_src}…\n")
            # Phi-3/4 ship with native transformers support; remote modeling_phi3.py
            # can break on newer transformers (LossKwargs). Prefer trust_remote_code=False.
            trust_remote = True
            try:
                from pathlib import Path as _P
                import json as _j

                _cfgp = _P(load_src) / "config.json"
                if _cfgp.is_file():
                    _cfg = _j.loads(_cfgp.read_text(encoding="utf-8"))
                    _mt = str(_cfg.get("model_type") or "").lower()
                    _arches = " ".join(str(a) for a in (_cfg.get("architectures") or []))
                    if _mt == "phi3" or "Phi3ForCausalLM" in _arches:
                        trust_remote = False
            except Exception:
                pass
            tok = AutoTokenizer.from_pretrained(load_src, trust_remote_code=trust_remote)
            dtype = torch.float16 if getattr(torch.backends, "mps", None) and torch.backends.mps.is_available() else torch.float32
            model = AutoModelForCausalLM.from_pretrained(
                load_src,
                torch_dtype=dtype,
                trust_remote_code=trust_remote,
                low_cpu_mem_usage=True,
            )
            if getattr(torch.backends, "mps", None) and torch.backends.mps.is_available():
                model = model.to("mps")
            model.eval()
            _PREVIEW_PIPES[load_src] = (tok, model)
            sys.stderr.write(f"[windhover] small model ready: {load_src}\n")
        tok, model = _PREVIEW_PIPES[load_src]
        if selected == "windhover/chat-preview":
            system = (
                "You are Windhover Chat Preview, a small on-device instruct model "
                f"({repo}). You are NOT Kimi, Qwen, DeepSeek, GLM, Llama, or any "
                "frontier MoE. Be honest if asked which model you are. "
                "Answer clearly with Markdown when helpful."
            )
        else:
            system = (
                f"You are {display}, running locally in Windhover from {repo}. "
                "Be honest about which model you are. Answer clearly with Markdown when helpful."
            )
        chat = [{"role": "system", "content": system}]
        for m in messages:
            role = m.get("role") or "user"
            content = (m.get("content") or "").strip()
            if content and role in ("user", "assistant", "system"):
                chat.append({"role": role, "content": content})
        if not any(m["role"] == "user" for m in chat):
            return "empty prompt", {}
        if hasattr(tok, "apply_chat_template") and tok.chat_template:
            prompt = tok.apply_chat_template(chat, tokenize=False, add_generation_prompt=True)
        else:
            prompt = "\n".join(f"{m['role']}: {m['content']}" for m in chat) + "\nassistant:"
        inputs = tok(prompt, return_tensors="pt")
        device = next(model.parameters()).device
        inputs = {k: v.to(device) for k, v in inputs.items()}
        gen_kwargs = {
            "max_new_tokens": max(16, min(int(max_tokens), 512)),
            "pad_token_id": tok.pad_token_id or tok.eos_token_id,
        }
        # Honor full eos_token_id lists (Phi-4: [<|end|>, <|endoftext|>]).
        eos_ids = getattr(model.config, "eos_token_id", None)
        try:
            import json as _json
            from pathlib import Path as _Path

            gcfg = _Path(load_src) / "generation_config.json"
            if gcfg.is_file():
                ge = _json.loads(gcfg.read_text(encoding="utf-8")).get("eos_token_id")
                if ge is not None:
                    eos_ids = ge
        except Exception:
            pass
        if eos_ids is not None:
            gen_kwargs["eos_token_id"] = eos_ids
        if float(temperature) > 0:
            gen_kwargs.update(do_sample=True, temperature=max(float(temperature), 0.05))
        else:
            gen_kwargs["do_sample"] = False
        with torch.inference_mode():
            out = model.generate(**inputs, **gen_kwargs)
        new_tokens = out[0][inputs["input_ids"].shape[-1] :]
        text = _clean_chat_text(tok.decode(new_tokens, skip_special_tokens=True))
        elapsed = max(time.perf_counter() - t0, 1e-6)
        ntok = int(new_tokens.numel()) if hasattr(new_tokens, "numel") else len(new_tokens)
        stats = {
            "rss_mb": round(_rss_mb(), 1),
            "latency_ms": round(elapsed * 1000, 1),
            "tokens_per_sec": round(ntok / elapsed, 2),
            "completion_tokens": ntok,
            "backend": "preview",
            "selected_model": selected,
            "preview_model": repo,
            "family": meta.get("family") or "kestrel",
            "engine": str(ENGINE_BIN),
        }
        _LAST_STATS.update(stats)
        return text or "(empty preview generation)", stats
    except Exception as e:
        err = f"{type(e).__name__}: {e}"
        sys.stderr.write(f"[windhover] preview chat failed: {err}\n")
        if not _transformers_available():
            return (
                "This model needs windhover-engine (not transformers). "
                "The engine path was unavailable and torch/transformers are not "
                "bundled in the desktop app. Try re-installing the model from Library, "
                "or restart the app so Windhover can convert weights for the engine.\n"
                f"Details: {err}",
                {
                    "backend": "preview",
                    "error": err,
                    "selected_model": selected,
                    "preview_model": repo,
                    "engine_active": False,
                },
            )
        return (
            "Small-model chat failed to load. Run: pip install transformers torch\n"
            f"Details: {err}",
            {"backend": "preview", "error": err, "selected_model": selected, "preview_model": repo},
        )


def _engine_chat(
    snap: Path,
    prompt: str,
    max_tokens: int,
    temperature: float,
    *,
    messages: list | None = None,
    on_delta=None,
) -> tuple[str, dict]:
    import time

    if not ENGINE_BIN.is_file():
        raise EngineInactiveError(
            "Windhover engine is not active — binary missing. "
            "Build it with `./windhover build`, then restart the app.",
            detail=f"expected {ENGINE_BIN}",
        )

    t0 = time.perf_counter()
    formatted = _format_engine_prompt(snap, messages, prompt)
    env = _engine_env(snap, None)
    env["PROMPT"] = formatted
    env["COLI_PROMPT"] = formatted
    env["NGEN"] = str(max_tokens)
    env["TEMP"] = str(temperature)
    env["QUIET"] = "1"
    env["DRAFT"] = "0"
    env["WH_JSON_STATS"] = "1"
    # Prefer accuracy in Chat; speed seekers can set WH_SPARSE explicitly.
    env.setdefault("WH_SPARSE", "0")

    wh_stats: dict = {}

    def _dec(b: bytes) -> str:
        return (b or b"").decode("utf-8", errors="replace").strip()

    try:
        if on_delta is None:
            p = subprocess.run(
                [str(ENGINE_BIN), "64", "4", "4"],
                cwd=str(ENGINE_DIR),
                env=env,
                capture_output=True,
            )
            raw_out, err, rc = p.stdout, _dec(p.stderr), p.returncode
        else:
            # stream stdout bytes to the client as they arrive
            proc = subprocess.Popen(
                [str(ENGINE_BIN), "64", "4", "4"],
                cwd=str(ENGINE_DIR),
                env=env,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
            )
            chunks: list[bytes] = []
            pending = b""
            while True:
                b = proc.stdout.read(64)
                if not b:
                    break
                chunks.append(b)
                pending += b
                # hold back a partial UTF-8 tail and anything after the stats marker
                if b"@@WH_STATS@@" in pending:
                    emit, _, _ = pending.partition(b"@@WH_STATS@@")
                    pending = b""
                else:
                    emit, pending = pending, b""
                    for back in range(1, min(4, len(emit)) + 1):
                        if emit[-back] & 0xC0 == 0xC0:  # UTF-8 lead byte in the tail
                            pending = emit[-back:]
                            emit = emit[:-back]
                            break
                if emit:
                    try:
                        on_delta(_clean_chat_text(emit.decode("utf-8", errors="replace"), soft=True))
                    except Exception:
                        proc.kill()
                        raise
            raw_out = b"".join(chunks)
            err = _dec(proc.stderr.read())
            rc = proc.wait()
    except FileNotFoundError as e:
        raise EngineInactiveError(
            "Windhover engine is not active — could not start windhover-engine.",
            detail=str(e),
        ) from e
    except OSError as e:
        raise EngineInactiveError(
            "Windhover engine is not active — failed to launch windhover-engine.",
            detail=str(e),
        ) from e

    text = _dec(raw_out)
    if "@@WH_STATS@@" in text:
        text, _, tail = text.partition("@@WH_STATS@@")
        try:
            wh_stats = json.loads(tail.strip().splitlines()[0])
        except Exception:
            wh_stats = {}
    text = _clean_chat_text(text)

    elapsed = max(time.perf_counter() - t0, 1e-6)
    meta = _snap_meta(snap)
    # Hard failure: process crashed / refused — surface as engine inactive.
    if rc != 0:
        detail = err or f"exit code {rc}"
        raise EngineInactiveError(
            "Windhover engine is not active — the engine process failed while "
            "running this model. Rebuild with `./windhover build`, re-convert "
            "the pack (`./windhover convert …`), or pick another Library model.",
            detail=detail[:2000],
        )
    # Never surface engine stderr logs as the chat answer.
    if not text:
        text = (
            "The model returned an empty reply. Try again with a shorter prompt, "
            "or pick a different installed model."
        )
    bad = sum(
        1
        for ch in text
        if ch == "\ufffd" or (ord(ch) < 32 and ch not in "\n\t") or ord(ch) > 126
    )
    if text and bad > max(3, len(text) // 3):
        text = (
            "windhover-engine ran this pack, but the output is not readable text. "
            "Install a real Hugging Face Mac 16GB model from Library, or re-download weights."
        )
    ntok = int(wh_stats.get("tokens") or max(1, len((text or "").split())))
    stats = {
        "rss_mb": round(_rss_mb(), 1),
        "latency_ms": round(elapsed * 1000, 1),
        "tokens_per_sec": wh_stats.get("decode_tok_s") or round(ntok / elapsed, 2),
        "completion_tokens": ntok,
        "backend": "windhover-engine",
        "engine_active": True,
        "selected_model": meta.get("id") or snap.name,
        "preview_model": None,
        "family": meta.get("family"),
        "engine": str(ENGINE_BIN),
    }
    if wh_stats:
        stats["windhover"] = {
            "decode_tok_s": wh_stats.get("decode_tok_s"),
            "prefill_tok_s": wh_stats.get("prefill_tok_s"),
            "footprint_gb": wh_stats.get("footprint_gb"),
            "sparsity_pct": wh_stats.get("sparsity_pct"),
            "bytes_per_tok": wh_stats.get("bytes_per_tok"),
            "au_hit_pct": wh_stats.get("au_hit_pct"),
            "forwards": wh_stats.get("forwards"),
        }
    _LAST_STATS.update(stats)
    return _clean_chat_text(text) if text else text, stats


def _agent_run(
    *,
    snap: Path | None,
    workspace: Path,
    prompt: str,
    max_steps: int = 8,
    max_tokens: int = 256,
    temperature: float = 0.2,
    ollama_model: str | None = None,
    on_progress=None,
) -> dict:
    """Host-side tool loop: local LLM proposes tools; we execute under workspace."""
    if _agent_ws is None:
        return {"ok": False, "error": "agent_workspace module missing"}
    root = workspace.resolve()
    if not root.is_dir():
        return {"ok": False, "error": f"workspace not a directory: {root}"}

    def _progress(message: str, **extra) -> None:
        if callable(on_progress):
            try:
                on_progress(message=message, **extra)
            except Exception:
                pass

    if ollama_model:
        mode = "ollama"
    else:
        if snap is None or not snap.is_dir():
            return {"ok": False, "error": "model not installed"}
        mode = _chat_mode(snap)
        if mode == "blocked":
            return {"ok": False, "error": "model is a fake stub — uninstall it"}
        if mode not in ("preview", "engine"):
            return {"ok": False, "error": f"model not chat-capable (mode={mode})"}
        if mode == "preview" and not _has_real_weights(snap):
            return {"ok": False, "error": "model has no real Hugging Face weights"}
        if mode == "engine" and not _ensure_engine_pack(snap, blocking=False):
            if _transformers_available() and _has_real_weights(snap):
                mode = "preview"
            elif _windhover_supported(snap) and _has_real_weights(snap):
                job_id = _start_prepare_job(snap)
                return {
                    "ok": False,
                    "error": (
                        "Preparing this model for windhover-engine (converting weights). "
                        "This can take several minutes for Phi/Gemma. Wait for the progress "
                        "bar, then send your message again."
                    ),
                    "code": "engine_preparing",
                    "job_id": job_id,
                    "engine_active": False,
                }
            else:
                detail = _LAST_CONVERT_ERROR or "unknown convert error"
                return {
                    "ok": False,
                    "error": (
                        "Engine could not prepare this model (KPK convert failed). "
                        f"{detail}"
                    ),
                    "detail": detail,
                    "code": "engine_inactive",
                }

    steps: list[dict] = []
    tool_results: list[dict] = []
    final_summary = ""
    last_text = ""
    wrote_ok = False
    echo_retries = 0
    prompt_l = prompt.lower()
    edit_intent = any(
        w in prompt_l
        for w in (
            "edit ",
            "change ",
            "insert ",
            "fix ",
            "write ",
            "create ",
            "update ",
            "refactor ",
            "docstring",
            "str_replace",
            "implement ",
            "add a ",
            "add the ",
            "add an ",
            "add docstring",
            "add comment",
            "add function",
            "add method",
            "add file",
        )
    ) or prompt_l.strip().startswith(("edit", "fix", "write", "create", "implement", "refactor"))
    explore_intent = (not edit_intent) and any(
        w in prompt_l
        for w in (
            "what is",
            "what's",
            "whats ",
            "explain",
            "describe",
            "summarize",
            "overview",
            "codebase",
            "this project",
            "this repo",
            "this folder",
            "how does",
            "list ",
        )
    )

    _progress("Starting…", step=0, steps=[], phase="start")

    for step_i in range(max(1, min(int(max_steps), 12))):
        _progress(
            f"Step {step_i + 1}: waiting on the model…",
            step=step_i + 1,
            steps=list(steps),
            phase="thinking",
        )
        messages = _agent_ws.build_agent_messages(
            user_prompt=prompt,
            workspace_root=str(root),
            tool_results=tool_results or None,
        )
        if explore_intent and step_i == 0 and not tool_results:
            messages.append(
                {
                    "role": "user",
                    "content": (
                        "This is an explore/question task (not an edit). "
                        "Call list_dir on . first, then finish with a clear answer. "
                        "Do not invent files or write anything."
                    ),
                }
            )
        if edit_intent and not wrote_ok and step_i > 0:
            messages.append(
                {
                    "role": "user",
                    "content": (
                        "You have not successfully written a file yet. "
                        "You MUST call str_replace or write_file before finish. "
                        "Do not call finish until a write tool returns ok:true. "
                        "Stay on the USER TASK — do not invent a calculator or hello.py demo."
                    ),
                }
            )
        if mode == "ollama":
            text, stats = _ollama_chat(
                messages, max_tokens, temperature, model_tag=str(ollama_model)
            )
        elif mode == "preview":
            text, stats = _preview_chat(messages, max_tokens, temperature, snap=snap)
        else:
            if not ENGINE_BIN.is_file():
                return {
                    "ok": False,
                    "error": (
                        "Windhover engine is not active — binary missing. "
                        "Run `./windhover build`, then restart the app."
                    ),
                    "code": "engine_inactive",
                    "engine_active": False,
                }
            flat = "\n".join(f"{m['role']}: {m['content']}" for m in messages)
            try:
                text, stats = _engine_chat(
                    snap, flat[-4000:], max_tokens, temperature, messages=messages
                )
            except EngineInactiveError as e:
                return {
                    "ok": False,
                    "error": str(e),
                    "detail": e.detail,
                    "code": "engine_inactive",
                    "engine_active": False,
                }
        last_text = _clean_chat_text(text or "")

        if _agent_ws.looks_like_format_echo(last_text, prompt) and echo_retries < 2:
            echo_retries += 1
            listing = (
                ", ".join(p.name for p in sorted(root.iterdir())[:12])
                if root.is_dir()
                else ""
            )
            tool_results = [
                {
                    "ok": False,
                    "error": (
                        "Rejected: reply looked like a canned demo (calculator/hello.py), "
                        "not the user task. Call ONE real tool for the USER TASK only"
                        + (f" (workspace has: {listing})." if listing else ".")
                    ),
                }
            ]
            steps.append(
                {
                    "step": step_i + 1,
                    "assistant": last_text[:4000],
                    "tool_calls": [],
                    "tool_results": list(tool_results),
                    "echo_rejected": True,
                    "stats": {
                        "tokens_per_sec": stats.get("tokens_per_sec"),
                        "latency_ms": stats.get("latency_ms"),
                        "backend": stats.get("backend"),
                    },
                }
            )
            _progress("Rejected demo echo — retrying…", step=step_i + 1, steps=list(steps), phase="retry")
            continue

        calls = _agent_ws.parse_tool_calls(last_text)
        if len(calls) > 1:
            calls = calls[:1]
        step: dict = {
            "step": step_i + 1,
            "assistant": last_text[:4000],
            "tool_calls": calls,
            "tool_results": [],
            "stats": {
                "tokens_per_sec": stats.get("tokens_per_sec"),
                "latency_ms": stats.get("latency_ms"),
                "backend": stats.get("backend"),
            },
        }
        if not calls:
            if edit_intent and not wrote_ok and step_i + 1 < max_steps:
                tool_results = [
                    {
                        "ok": False,
                        "error": "No tool call parsed. Emit a ```tool JSON block (str_replace or write_file).",
                    }
                ]
                step["tool_results"] = tool_results
                steps.append(step)
                _progress("Waiting for a valid tool call…", step=step_i + 1, steps=list(steps), phase="retry")
                continue
            final_summary = last_text.strip() or "(no tool calls; empty reply)"
            step["done"] = True
            steps.append(step)
            break

        tool_results = []
        finished = False
        name = ""
        for call in calls:
            name = (call.get("name") or call.get("tool") or "").strip()
            _progress(
                f"Running {name or 'tool'}…",
                step=step_i + 1,
                steps=list(steps) + [step],
                phase="tool",
                tool=name,
            )
            if name == "finish" and edit_intent and not wrote_ok:
                result = {
                    "tool": "finish",
                    "ok": False,
                    "error": "Refused finish: no successful write yet. Call str_replace or write_file first.",
                }
            else:
                result = _agent_ws.run_tool(root, call)
            tool_results.append(result)
            step["tool_results"].append(result)
            if name in ("write_file", "str_replace") and result.get("ok"):
                wrote_ok = True
            if name == "finish" and result.get("ok"):
                final_summary = result.get("summary") or "done"
                finished = True
        steps.append(step)
        if finished:
            break

    if ollama_model:
        model_id = f"ollama/{ollama_model}"
    else:
        model_id = _snap_meta(snap).get("id") or (snap.name if snap else None)
    out = {
        "ok": True,
        "workspace": str(root),
        "model": model_id,
        "steps": steps,
        "summary": final_summary or last_text[:2000],
        "step_count": len(steps),
        "wrote": wrote_ok,
    }
    _progress("Done", step=len(steps), steps=list(steps), phase="done")
    return out



def _ensure_nofile() -> None:
    if sys.platform == "win32":
        return
    try:
        import resource

        soft, hard = resource.getrlimit(resource.RLIMIT_NOFILE)
        want = min(65536 if hard == resource.RLIM_INFINITY else hard, 65536)
        if soft < want:
            resource.setrlimit(resource.RLIMIT_NOFILE, (want, hard))
    except (ImportError, ValueError, OSError):
        pass


def cmd_build(_: argparse.Namespace) -> int:
    """Build windhover-engine (make on Unix; mingw32-make/make on Windows)."""
    env = os.environ.copy()
    # Refresh ENGINE_BIN after build (module-level Path may have been missing).
    make_cmds: list[list[str]] = []
    if sys.platform == "win32":
        for cand in ("mingw32-make", "make", "gmake"):
            if shutil.which(cand):
                make_cmds.append([cand, "ARCH=native"])
                break
        if not make_cmds:
            print("windhover build: need mingw32-make or make on PATH", file=sys.stderr)
            return 1
    else:
        make_cmds.append(["make", "ARCH=native"])
    rc = subprocess.call(make_cmds[0], cwd=str(ENGINE_DIR), env=env)
    # Rebind global for subsequent commands in the same process
    global ENGINE_BIN
    ENGINE_BIN = _engine_bin()
    return rc


def cmd_oracle(_: argparse.Namespace) -> int:
    if not ENGINE_BIN.is_file() and cmd_build(argparse.Namespace()) != 0:
        return 1
    env = os.environ.copy()
    env["SNAP"] = str(ENGINE_DIR / "fixtures" / "glm_tiny") if sys.platform == "win32" else "./fixtures/glm_tiny"
    env["TF"] = "1"
    return subprocess.call(
        [str(ENGINE_BIN), "64", "16", "16"], cwd=str(ENGINE_DIR), env=env
    )


