def _engine_snap(model: Path) -> Path:
    """Prefer the Windhover KPK pack directory when present."""
    kpk = model / "kpk"
    if kpk.is_dir() and (_has_kpk(model) or (kpk / "kestrel.json").is_file() or any(kpk.glob("kpk-*.safetensors"))):
        return kpk
    return model


def _engine_env(model: Path, ram: float | None) -> dict[str, str]:
    env = os.environ.copy()
    env["SNAP"] = str(_engine_snap(model))
    env.pop("TF", None)
    if ram:
        env["RAM_GB"] = str(ram)
        env["COLI_HARD_CAP"] = "1"
    return env


def cmd_chat(ns: argparse.Namespace) -> int:
    if not ENGINE_BIN.is_file():
