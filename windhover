class _SafeTextIO:
    """Text stream wrapper that never raises UnicodeEncodeError on write."""

    def __init__(self, stream):
        self._stream = stream

    @property
    def encoding(self) -> str:
        if self._stream is None:
            return "utf-8"
        return getattr(self._stream, "encoding", None) or "utf-8"

    def write(self, s):
        if self._stream is None:
            return 0 if s is None else len(s)
        if not isinstance(s, str):
            return self._stream.write(s)
        try:
            return self._stream.write(s)
        except UnicodeEncodeError:
            enc = self.encoding
            safe = s.encode(enc, errors="replace").decode(enc, errors="replace")
            return self._stream.write(safe)

    def writelines(self, lines):
        for line in lines:
            self.write(line)

    def flush(self):
        if self._stream is not None and hasattr(self._stream, "flush"):
            self._stream.flush()

    def reconfigure(self, *args, **kwargs):
        if self._stream is not None and hasattr(self._stream, "reconfigure"):
            return self._stream.reconfigure(*args, **kwargs)
        return None

    def isatty(self):
        if self._stream is None:
            return False
        try:
            return bool(self._stream.isatty())
        except Exception:
            return False

    def fileno(self):
        if self._stream is None:
            raise io.UnsupportedOperation("fileno")
        return self._stream.fileno()

    def __getattr__(self, name):
        if self._stream is None:
            raise AttributeError(name)
        return getattr(self._stream, name)


class _NullTextIO(io.TextIOBase):
    """Sink for windowed PyInstaller builds where stdout/stderr are None."""

    encoding = "utf-8"

    def write(self, s):
        return 0 if s is None else len(s)

    def flush(self):
        return None


def _configure_stdio_utf8() -> None:
    """Make stdout/stderr UTF-8-safe so download progress cannot crash on Windows."""
    for name in ("stdout", "stderr"):
        stream = getattr(sys, name, None)
        if stream is None:
            setattr(sys, name, _SafeTextIO(_NullTextIO()))
            continue
        if isinstance(stream, _SafeTextIO):
            continue
        try:
            stream.reconfigure(encoding="utf-8", errors="replace")
        except (AttributeError, OSError, ValueError):
            pass
        # Always wrap: reconfigure is a no-op on some redirected/legacy handles.
        setattr(sys, name, _SafeTextIO(stream))
    if sys.platform == "win32":
        try:
            import ctypes

            ctypes.windll.kernel32.SetConsoleOutputCP(65001)
            ctypes.windll.kernel32.SetConsoleCP(65001)
        except Exception:
            pass


