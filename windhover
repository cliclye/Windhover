def _dense_loadtime_ok(snap: Path) -> bool:
    """True when windhover-engine dense.c can load raw HF weights (no KPK).

    Matches engine/runtime/dense.c dense_is_arch: qwen2/3, llama, mistral.
    Gemma/Phi need a KPK pack (windhover.c) — see _windhover_supported.
    """
    cfg_path = snap / "config.json"
    if not cfg_path.is_file():
        return False
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
    except Exception:
        return False
    if cfg.get("n_routed_experts") or cfg.get("num_experts") or cfg.get("num_local_experts"):
        return False
    arches = " ".join(str(a) for a in (cfg.get("architectures") or []))
    if any(
        x in arches
        for x in (
            "MixtralForCausalLM",
            "Qwen2MoeForCausalLM",
            "Qwen3MoeForCausalLM",
            "Gemma2ForCausalLM",
            "Gemma3ForCausalLM",
            "Phi3ForCausalLM",
        )
    ):
        return False
    mt = str(cfg.get("model_type") or "").lower()
    if mt in ("gemma2", "gemma3", "gemma", "phi3", "phi"):
        return False
    if mt in ("qwen2", "qwen3", "llama", "mistral"):
        return True
    return any(
        x in arches
        for x in (
            "Qwen2ForCausalLM",
            "Qwen3ForCausalLM",
            "LlamaForCausalLM",
            "MistralForCausalLM",
        )
    )


